@model WebNoiThatHoaHome.Models.Employee
@{
    ViewData["Title"] = "Thêm Nhân sự mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase mb-0"><i class="fa-solid fa-user-plus text-primary me-2"></i>Thêm Nhân sự</h3>
        <a href="/Admin/Employee/Index" class="btn btn-outline-dark rounded-0"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
    </div>

    @* Căn giữa Form *@
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card rounded-0 border shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-bold">Chọn Tài khoản <span class="text-danger">*</span></label>
                            <select asp-for="UserId" class="form-select rounded-0" asp-items="ViewBag.UserId" required>
                                <option value="">-- Chọn User để làm nhân viên --</option>
                            </select>
                            <div class="form-text mt-2"><i class="fa-solid fa-circle-info text-primary me-1"></i>Chỉ hiển thị những tài khoản chưa phải là nhân viên.</div>
                        </div>

                        @* ĐÃ THAY ĐỔI: Chuyển ô Input thành Dropdown Select *@
                        <div class="mb-4">
                            <label class="form-label fw-bold">Chuyên môn / Vị trí</label>
                            <select asp-for="Specialization" class="form-select rounded-0">
                                <option value="Chưa phân công" selected>Chưa phân công</option>
                                <option value="Kỹ thuật viên khảo sát">Kỹ thuật viên khảo sát</option>
                                <option value="Kiến trúc sư">Kiến trúc sư</option>
                                <option value="Kỹ thuật viên lắp đặt">Kỹ thuật viên lắp đặt</option>
                                <option value="Nhân viên giao hàng">Nhân viên giao hàng</option>
                                
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Trạng thái công việc</label>
                            <select asp-for="Status" class="form-select rounded-0">
                                <option value="Available" selected>Đang rảnh (Sẵn sàng nhận việc)</option>
                                <option value="Busy">Đang bận (Đang thi công)</option>
                                <option value="OnLeave">Nghỉ phép</option>
                            </select>
                        </div>

                        <hr class="my-4" />

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary rounded-0 py-2 fw-bold">
                                <i class="fa-solid fa-floppy-disk me-2"></i> LƯU NHÂN SỰ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>