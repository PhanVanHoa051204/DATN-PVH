@model WebNoiThatHoaHome.Models.Employee
@{
    ViewData["Title"] = "Chỉnh sửa Nhân sự";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase mb-0"><i class="fa-solid fa-user-pen text-primary me-2"></i>Chỉnh sửa Nhân sự</h3>
        <a href="/Admin/Employee/Index" class="btn btn-outline-dark rounded-0"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card rounded-0 border shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" name="EmployeeId" value="@Model.EmployeeId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted">Tài khoản Nhân viên</label>
                            <input type="text" class="form-control rounded-0 bg-light" value="@Model.User?.FullName - @Model.User?.Phone" readonly />
                            <small class="text-muted fst-italic">Thông tin cá nhân liên kết từ tài khoản người dùng, không thể sửa tại đây.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Chuyên môn / Vị trí</label>
                            <select name="Specialization" class="form-select rounded-0">
                                <option value="Chưa phân công" selected="@(Model.Specialization == "Chưa phân công")">Chưa phân công</option>
                                <option value="Kỹ thuật viên khảo sát" selected="@(Model.Specialization == "Kỹ thuật viên khảo sát")">Kỹ thuật viên khảo sát</option>
                                <option value="Kiến trúc sư" selected="@(Model.Specialization == "Kiến trúc sư")">Kiến trúc sư</option>
                                <option value="Kỹ thuật viên lắp đặt" selected="@(Model.Specialization == "Kỹ thuật viên lắp đặt")">Kỹ thuật viên lắp đặt</option>
                                <option value="Nhân viên giao hàng" selected="@(Model.Specialization == "Nhân viên giao hàng")">Nhân viên giao hàng</option>
                                
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Trạng thái công việc</label>
                            <select name="Status" class="form-select rounded-0">
                                <option value="Available" selected="@(Model.Status == "Available")">Đang rảnh (Sẵn sàng nhận việc)</option>
                                <option value="Busy" selected="@(Model.Status == "Busy")">Đang bận (Đang thi công)</option>
                                <option value="OnLeave" selected="@(Model.Status == "OnLeave")">Nghỉ phép</option>
                            </select>
                        </div>

                        <hr class="my-4" />

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary rounded-0 py-2 fw-bold">
                                <i class="fa-solid fa-floppy-disk me-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>