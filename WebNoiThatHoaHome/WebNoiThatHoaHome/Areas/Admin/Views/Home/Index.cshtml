@model WebNoiThatHoaHome.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển (Dashboard)";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white shadow-sm border-0 rounded-3 h-100">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-2">Người dùng đăng ký</h6>
                <h2 class="display-5 fw-bold mb-0">@Model.TotalUsers.ToString("N0")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white shadow-sm border-0 rounded-3 h-100">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-2">Tổng đơn hàng</h6>
                <h2 class="display-5 fw-bold mb-0">@Model.TotalOrders.ToString("N0")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-warning text-dark shadow-sm border-0 rounded-3 h-100">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-2">Tổng doanh thu</h6>
                <h2 class="display-5 fw-bold mb-0">@Model.TotalRevenue.ToString("N0") ₫</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-header bg-white py-3 fw-bold">
                <i class="fa-solid fa-chart-line me-2 text-primary"></i> Biểu đồ Doanh thu (7 ngày qua)
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 rounded-3 h-100">
            <div class="card-header bg-white py-3 fw-bold">
                <i class="fa-solid fa-chart-pie me-2 text-success"></i> Tỉ lệ trạng thái đơn
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <canvas id="orderStatusChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-3 mb-5">
    <div class="card-header bg-white py-3 fw-bold">
        <i class="fa-solid fa-list-ul me-2 text-primary"></i> 5 Đơn hàng mới nhất
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentOrders != null && Model.RecentOrders.Count > 0)
                    {
                        foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td class="px-4 fw-bold text-primary">#ORD-@order.OrderId.ToString("D3")</td>
                                <td>@(order.User?.FullName ?? "Khách vãng lai")</td>
                                <td>@(order.OrderDate?.ToString("dd/MM/yyyy HH:mm"))</td>
                                <td class="fw-bold text-danger">@(order.TotalAmount?.ToString("N0") ?? "0") ₫</td>
                                <td>
                                    @if (order.PaymentStatus == "Success")
                                    {
                                        <span class="badge bg-success">Đã thanh toán</span>
                                    }
                                    else if (order.PaymentStatus == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@order.PaymentStatus</span>
                                    }
                                </td>
                                <td>
                                    @if (order.OrderStatus == "New")
                                    {
                                        <span class="badge bg-primary">Mới</span>
                                    }
                                    else if (order.OrderStatus == "Processing")
                                    {
                                        <span class="badge bg-info">Đang xử lý</span>
                                    }
                                    else if (order.OrderStatus == "Completed")
                                    {
                                        <span class="badge bg-success">Hoàn thành</span>
                                    }
                                    else if (order.OrderStatus == "Cancelled")
                                    {
                                        <span class="badge bg-danger">Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@order.OrderStatus</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">Chưa có đơn hàng nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Lấy dữ liệu ĐỘNG từ C#
        const revenueLabels = @Html.Raw(ViewBag.ChartLabels);
        const revenueData = @Html.Raw(ViewBag.ChartData);
        const doughnutData = @Html.Raw(ViewBag.DoughnutData);

        // ==========================================
        // 1. BIỂU ĐỒ ĐƯỜNG: DOANH THU 7 NGÀY
        // ==========================================
        const ctxLine = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctxLine, {
            type: 'line',
            data: {
                labels: revenueLabels,
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: revenueData,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.2)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#0d6efd',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let value = context.parsed.y;
                                return value.toLocaleString('vi-VN') + ' ₫';
                            }
                        }
                    }
                },
                animation: {
                    x: { duration: 3000, from: 0 },
                    y: { duration: 2000, from: 500, easing: 'easeOutQuart' }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                if(value >= 1000000) return (value / 1000000) + ' Tr';
                                if(value >= 1000) return (value / 1000) + ' K';
                                return value;
                            }
                        }
                    }
                }
            }
        });

        // ==========================================
         // 2. BIỂU ĐỒ TRÒN: TRẠNG THÁI ĐƠN HÀNG (ÉP CHẠY 100%)
         // ==========================================
         const ctxPie = document.getElementById('orderStatusChart').getContext('2d');

         // Tạo biểu đồ nhưng gán nó vào 1 biến tên là orderPieChart
         const orderPieChart = new Chart(ctxPie, {
             type: 'doughnut',
             data: {
                 labels: ['Mới', 'Đang xử lý', 'Đang giao', 'Hoàn thành', 'Đã hủy'],
                 datasets: [{
                     data: doughnutData,
                     backgroundColor: [
                         '#0d6efd', '#0dcaf0', '#ffc107', '#198754', '#dc3545'
                     ],
                     borderWidth: 2,
                     hoverOffset: 12
                 }]
             },
             options: {
                 responsive: true,
                 cutout: '65%',
                 circumference: 0, // BÍ QUYẾT 1: Lúc đầu ép nó bằng 0 độ (Tàng hình)
                 plugins: {
                     legend: { position: 'bottom' }
                 },
                 animation: {
                     duration: 2000,  // BÍ QUYẾT 2: Kéo dài thời gian vẽ thành 6 giây
                     easing: 'linear' // Quay đều như kim đồng hồ
                 }
             }
         });

         // BÍ QUYẾT 3: Hẹn giờ 0.5s sau khi load trang mới bắt đầu ra lệnh vẽ đủ 360 độ
         setTimeout(() => {
             orderPieChart.options.circumference = 360; // Ép thành 360 độ (1 vòng tròn)
             orderPieChart.update(); // Ra lệnh vẽ lại!
         }, 500);
    </script>
}