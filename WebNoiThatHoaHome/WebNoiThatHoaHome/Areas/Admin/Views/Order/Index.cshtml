@model IEnumerable<WebNoiThatHoaHome.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid my-4">
    <h3 class="fw-bold text-uppercase mb-4">Quản lý Đơn hàng</h3>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMsg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card rounded-0 border shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã ĐH</th>
                            <th>Ngày đặt</th>
                            <th style="width: 25%;">Thông tin giao hàng</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th style="width: 20%;">Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    <tbody>
                            @foreach (var item in Model)
                            {
                            <tr>
                                <td class="fw-bold">#@item.OrderId</td>

                                <td>@item.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>

                                <td style="font-size: 13px;">
                                        @item.ShippingAddress
                                </td>

                                <td class="text-danger fw-bold">@string.Format("{0:N0} ₫", item.TotalAmount)</td>

                                <td>
                                    <form action="/Admin/Order/UpdatePaymentStatus" method="post" class="d-flex align-items-center mb-0">
                                        <input type="hidden" name="orderId" value="@item.OrderId" />
                                        <input type="hidden" name="returnUrl" value="/Admin/Order/Index" />

                                        <select name="newPaymentStatus" class="form-select form-select-sm rounded-0 me-1" style="width: 135px; font-size: 13px;">
                                            <option value="Pending" selected="@(item.PaymentStatus == "Pending")">Chờ thanh toán</option>
                                            <option value="Success" selected="@(item.PaymentStatus == "Success")">Đã thanh toán</option>
                                            <option value="Failed" selected="@(item.PaymentStatus == "Failed")">Thanh toán lỗi</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-dark rounded-0" title="Cập nhật">
                                            <i class="fa-solid fa-check"></i>
                                        </button>
                                    </form>
                                </td>

                                <td>
                                    <form action="/Admin/Order/UpdateStatus" method="post" class="d-flex align-items-center mb-0">
                                        <input type="hidden" name="orderId" value="@item.OrderId" />
                                        <select name="newStatus" class="form-select form-select-sm rounded-0 me-1" style="width: 140px; font-size: 13px;">
                                            <option value="New" selected="@(item.OrderStatus == "New")">Chờ xác nhận</option>
                                            <option value="Processing" selected="@(item.OrderStatus == "Processing")">Đang xử lý</option>
                                            <option value="Delivering" selected="@(item.OrderStatus == "Delivering")">Đang giao hàng</option>
                                            <option value="Completed" selected="@(item.OrderStatus == "Completed")">Đã hoàn thành</option>
                                            <option value="Cancelled" selected="@(item.OrderStatus == "Cancelled")">Đã hủy</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-dark rounded-0" title="Cập nhật">
                                            <i class="fa-solid fa-floppy-disk"></i>
                                        </button>
                                    </form>
                                </td>

                                <td class="text-center">
                                    <a href="/Admin/Order/Details/@item.OrderId" class="btn btn-sm btn-outline-dark rounded-0" style="white-space: nowrap;">
                                        <i class="fa-solid fa-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                            }
                    </tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>