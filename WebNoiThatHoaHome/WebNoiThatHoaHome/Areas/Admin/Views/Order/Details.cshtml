@model WebNoiThatHoaHome.Models.Order
@{
    ViewData["Title"] = "Chi tiết Đơn hàng #" + Model.OrderId;
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase mb-0">Quản lý Đơn hàng <span class="text-danger">#@Model.OrderId</span></h3>
        <a href="/Admin/Order/Index" class="btn btn-outline-dark rounded-0"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại danh sách</a>
    </div>

    @* DÙNG 1 FORM DUY NHẤT BAO QUÁT *@
    <form asp-area="Admin" asp-controller="Order" method="post">
        @* Input ẩn dùng chung cho cả 2 hành động *@
        <input type="hidden" name="OrderId" value="@Model.OrderId" />
        <input type="hidden" name="orderId" value="@Model.OrderId" />

        <div class="row">
            @* ========================================== *@
            @* CỘT TRÁI (COL-8): THÔNG TIN GIAO HÀNG & SẢN PHẨM *@
            @* ========================================== *@
            <div class="col-lg-8 mb-4">

                @* KHỐI XỬ LÝ HỦY ĐƠN (Chỉ hiện khi khách yêu cầu hủy) *@
                @if (Model.OrderStatus == "PendingCancel")
                {
                    <div class="card border-warning shadow-sm mb-4 rounded-0">
                        <div class="card-header bg-warning text-dark fw-bold text-uppercase">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i> Xử lý yêu cầu hủy đơn
                        </div>
                        <div class="card-body bg-light">
                            <div class="alert alert-white border mb-3">
                                <strong class="d-block mb-2 text-primary">Lý do khách gửi:</strong>
                                <div style="white-space: pre-line; font-size: 13px;">@Model.CustomerNote</div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" formaction="/Admin/Order/ProcessCancelRequest?actionType=Approve" class="btn btn-danger px-4 rounded-0">Chấp nhận hủy</button>
                                <button type="submit" formaction="/Admin/Order/ProcessCancelRequest?actionType=Reject" class="btn btn-secondary px-4 rounded-0">Từ chối</button>
                            </div>
                            <small class="text-muted d-block mt-2">Lưu ý: Nội dung trong ô "Ghi chú & Phản hồi" bên phải sẽ được dùng làm câu trả lời cho khách.</small>
                        </div>
                    </div>
                }

                @* KHỐI THÔNG TIN GIAO HÀNG *@
                <div class="card rounded-0 border shadow-sm mb-4">
                    <div class="card-header bg-white text-dark rounded-0 text-uppercase fw-bold">
                        <i class="fa-solid fa-truck-fast text-success me-2"></i> Thông tin Giao hàng
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="fw-bold mb-1"><i class="fa-solid fa-location-dot text-danger me-1"></i> Địa chỉ nhận hàng:</label>
                            <input type="text" name="ShippingAddress" class="form-control rounded-0 bg-light" value="@Model.ShippingAddress" readonly />
                            <small class="text-muted mt-1 d-block">Ngày đặt: @Model.OrderDate?.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                </div>

                @* KHỐI DANH SÁCH SẢN PHẨM *@
                <div class="card rounded-0 border shadow-sm">
                    <div class="card-header bg-dark text-white rounded-0 text-uppercase fw-bold">Sản phẩm đã đặt</div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center">Đơn giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    var imgUrl = item.Product?.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? "/images/no-image.png";
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@imgUrl" style="width: 50px; height: 50px; object-fit: cover;" class="border rounded me-3">
                                                <div>
                                                    <div class="fw-bold">@item.Product?.ProductName</div>
                                                    <small class="text-muted">Mã: #@item.ProductId</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">@string.Format("{0:N0} ₫", item.UnitPrice)</td>
                                        <td class="text-center fw-bold">x @item.Quantity</td>
                                        <td class="text-end pe-4 fw-bold text-dark">@string.Format("{0:N0} ₫", item.UnitPrice * item.Quantity)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            @* ========================================== *@
            @* CỘT PHẢI (COL-4): THANH TOÁN, TRẠNG THÁI & GHI CHÚ *@
            @* ========================================== *@
            <div class="col-lg-4 mb-4">

                @* KHỐI GHI CHÚ & PHẢN HỒI *@
                <div class="card rounded-0 border shadow-sm mb-4">
                    <div class="card-header bg-white text-dark rounded-0 text-uppercase fw-bold">
                        <i class="fa-solid fa-pen-to-square text-primary me-2"></i> Ghi chú & Phản hồi
                    </div>
                    <div class="card-body">
                        <div class="p-2 mb-3 bg-light border" style="max-height: 150px; overflow-y: auto;">
                            <span style="white-space: pre-line; font-size: 14px;">@Model.CustomerNote</span>
                        </div>

                        <label class="fw-bold mb-1 text-primary">Viết phản hồi cho khách:</label>
                        <textarea name="adminNote" class="form-control rounded-0" rows="3" placeholder="Nhập câu trả lời..."></textarea>
                         <small class="text-muted mt-1 d-block">Bỏ trống nếu không muốn phản hồi thêm.</small>
                    </div>
                </div>

                @* KHỐI THANH TOÁN & TRẠNG THÁI *@
                <div class="card rounded-0 border shadow-sm mb-4">
                    <div class="card-header bg-white text-dark rounded-0 text-uppercase fw-bold">
                        <i class="fa-solid fa-credit-card text-info me-2"></i> Trạng thái & Thanh toán
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold">Phương thức TT:</span>
                            <span class="badge bg-secondary">@(Model.PaymentMethod == "BANK" ? "VNPAY" : "Thu hộ (COD)")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="fw-bold">Trạng thái TT:</span>
                            <span class="fw-bold @(Model.PaymentStatus == "Success" ? "text-success" : "text-warning")">
                                @(Model.PaymentStatus == "Success" ? "Đã thanh toán" : "Chờ thanh toán")
                            </span>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Cập nhật trạng thái ĐH:</label>
                            <select name="OrderStatus" class="form-select rounded-0 border-primary">
                                <option value="New" selected="@(Model.OrderStatus == "New")">Đơn mới</option>
                                <option value="Processing" selected="@(Model.OrderStatus == "Processing")">Đang xử lý</option>
                                <option value="Shipping" selected="@(Model.OrderStatus == "Shipping")">Đang giao hàng</option>
                                <option value="Completed" selected="@(Model.OrderStatus == "Completed")">Hoàn thành</option>
                                <option value="Cancelled" selected="@(Model.OrderStatus == "Cancelled")">Đã hủy</option>
                            </select>
                        </div>

                        <button type="submit" asp-action="EditOrder" class="btn btn-primary w-100 rounded-0 fw-bold">
                            <i class="fa-solid fa-floppy-disk me-2"></i> LƯU THAY ĐỔI
                        </button>
                    </div>
                </div>

                @* KHỐI TỔNG TIỀN *@
                @{
                    // Tính lại tiền hàng gốc (chưa trừ giảm giá)
                    decimal originalSubTotal = Model.OrderItems.Sum(i => i.UnitPrice * i.Quantity);

                    // Tính số tiền đã giảm
                    decimal discountAmount = 0;
                    if (Model.Voucher != null)
                    {
                        if (Model.Voucher.DiscountType == "Percent")
                        {
                            discountAmount = originalSubTotal * (Model.Voucher.DiscountValue / 100);
                        }
                        else
                        {
                            discountAmount = Model.Voucher.DiscountValue;
                        }
                    }
                }

                <div class="border-top pt-3 mt-3">
                    <div class="d-flex justify-content-between mb-2" style="font-size: 15px;">
                        <span class="text-muted">Tổng tiền hàng:</span>
                        <span class="fw-bold">@originalSubTotal.ToString("N0") đ</span>
                    </div>

                    @if (Model.Voucher != null)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success" style="font-size: 15px;">
                            <span>Mã giảm giá <b class="border px-1 rounded bg-light text-success">@Model.Voucher.Code</b>:</span>
                            <span class="fw-bold">- @discountAmount.ToString("N0") đ</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between mb-3" style="font-size: 15px;">
                        <span class="text-muted">Phí giao hàng:</span>
                        <span class="fw-bold">@((Model.ShippingFee ?? 0).ToString("N0")) đ</span>
                    </div>

                    <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                        <h5 class="fw-bold mb-0">TỔNG CỘNG:</h5>
                        <h5 class="fw-bold text-danger mb-0">@Model.TotalAmount?.ToString("N0") đ</h5>
                    </div>
                </div>
                
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({ 
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: '@Html.Raw(TempData["SuccessMsg"])',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true 
                    });
            </text>
        }
        });
    </script>
}