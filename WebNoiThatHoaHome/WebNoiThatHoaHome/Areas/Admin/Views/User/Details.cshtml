@model WebNoiThatHoaHome.Models.UserDetailViewModel
@{
    ViewData["Title"] = "Chi tiết Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-user-pen text-primary me-2"></i> Hồ sơ người dùng #@Model.UserId</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Details" method="post">
                    <input type="hidden" asp-for="UserId" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Họ và tên *</label>
                            <input type="text" asp-for="FullName" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Địa chỉ Email</label>
                            <input type="email" asp-for="Email" class="form-control bg-light" readonly>
                            <div class="form-text">Email dùng để đăng nhập, không thể thay đổi.</div>
                        </div>
                    </div>
                    <div class="row mb-3 bg-warning bg-opacity-10 p-3 rounded border border-warning">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-danger"><i class="fa-solid fa-key me-1"></i> Đổi mật khẩu mới cho khách hàng</label>
                            <input type="text" asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới vào đây... (Bỏ trống nếu không muốn đổi)">
                            <div class="form-text text-muted">Nếu bạn không nhập gì, mật khẩu cũ của khách sẽ được giữ nguyên.</div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" asp-for="Phone" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày đăng ký</label>
                            <input type="text" class="form-control bg-light" value="@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")" readonly>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Địa chỉ giao hàng mặc định</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>

                    <hr class="text-muted">

                    <h6 class="fw-bold text-danger mb-3"><i class="fa-solid fa-shield-halved me-2"></i>Khu vực Đặc quyền Admin</h6>

                    <div class="row mb-4 bg-light p-3 rounded">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phân quyền tài khoản</label>
                            <select asp-for="RoleId" asp-items="Model.Roles" class="form-select">
                                <option value="">-- Chọn quyền --</option>
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-center mt-4">
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input" type="checkbox" asp-for="IsDeleted">
                                <label class="form-check-label fw-bold ms-2 text-danger" for="IsDeleted">Khóa tài khoản này</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <a href="/Admin/User/Index" class="btn btn-outline-secondary me-2 px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-4 fw-bold"><i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>