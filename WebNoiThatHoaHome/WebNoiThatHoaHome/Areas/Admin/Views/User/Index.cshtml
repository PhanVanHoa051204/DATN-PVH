@model IEnumerable<WebNoiThatHoaHome.Models.User>
@{
    ViewData["Title"] = "Quản lý Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">

    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-users text-primary me-2"></i> Danh sách Khách hàng</h5>

        <div class="d-flex gap-2">
            <form asp-action="Index" method="get" class="input-group" style="width: 350px;">
                <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Tìm tên hoặc email...">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm
                </button>

                @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
                {
                    <a href="/Admin/User/Index" class="btn btn-outline-danger" title="Xóa tìm kiếm">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                }
            </form>

            <a href="/Admin/User/Create" class="btn btn-primary fw-bold">
                <i class="fa-solid fa-plus me-1"></i> Thêm mới
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3">ID</th>
                        <th class="py-3">Họ và tên</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">Vai trò</th>
                        <th class="py-3">Ngày đăng ký</th>
                        <th class="py-3">Trạng thái</th>
                        <th class="text-center py-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted fw-bold">#@item.UserId</td>
                                <td class="fw-bold text-dark">@item.FullName</td>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.Role != null && item.Role.RoleName.Contains("Admin"))
                                    {
                                        <span class="badge bg-danger px-2 py-1">Quản trị viên</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-2 py-1">Khách hàng</span>
                                    }
                                </td>
                                <td>@(item.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                <td>
                                    @if (item.IsDeleted == true)
                                    {
                                        <span class="badge bg-danger px-2 py-1">Đã khóa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-2 py-1">Hoạt động</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="/Admin/User/Details/@item.UserId" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a href="/Admin/User/Delete/@item.UserId" class="btn btn-sm btn-outline-danger ms-1" title="Khóa tài khoản" onclick="return confirm('Bạn có chắc chắn muốn vô hiệu hóa người dùng này?');">
                                        <i class="fa-solid fa-lock"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-users-slash fa-2x mb-3"></i><br />
                                Không tìm thấy khách hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>