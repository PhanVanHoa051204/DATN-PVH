@model IEnumerable<WebNoiThatHoaHome.Models.Appointment>
@{
    ViewData["Title"] = "Điều phối Lịch hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var employeeList = ViewBag.Employees as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-uppercase mb-0 text-primary">
            <i class="fa-solid fa-calendar-check me-2"></i>Điều phối Lịch hẹn
        </h4>

        <div class="d-flex align-items-center gap-3">
            <span class="badge bg-secondary py-2 px-3 shadow-sm">
                <i class="fa-solid fa-list-ol me-1"></i> Tổng số: @Model.Count() lịch hẹn
            </span>

            <a href="/Admin/Appointment/Trash" class="btn btn-outline-danger shadow-sm fw-bold px-3">
                <i class="fa-solid fa-trash-can me-1"></i> Thùng rác
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4 py-3">Mã LH</th>
                            <th class="py-3">Khách hàng</th>
                            <th class="py-3">Dịch vụ & Thời gian</th>
                            <th class="py-3" style="width: 220px;">Nhân sự phụ trách</th>
                            <th class="py-3" style="width: 180px;">Trạng thái</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted">Chưa có lịch hẹn nào.</td></tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@item.AppointmentId</td>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Customer?.FullName</div>
                                        <div class="small text-muted"><i class="fa-solid fa-phone me-1"></i> @item.Customer?.Phone</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-primary border border-primary mb-1">
                                            @item.ServiceType?.TypeName
                                        </span>
                                        <div class="small fw-bold text-dark">
                                            <i class="fa-regular fa-clock me-1"></i> @item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </td>

                                    @* Cột Nhân sự: Dùng Form riêng trong cell để tránh vỡ HTML *@
                                    <td>
                                        <form asp-action="QuickUpdate" method="post" class="d-inline">
                                            <input type="hidden" name="AppointmentId" value="@item.AppointmentId" />
                                            <select name="EmployeeId" class="form-select form-select-sm border-primary-subtle shadow-sm" onchange="this.form.submit()">
                                                <option value="">-- Chọn NV --</option>
                                                @foreach (var emp in employeeList)
                                                {
                                                    <option value="@emp.Value" selected="@(item.EmployeeId?.ToString() == emp.Value)">@emp.Text</option>
                                                }
                                            </select>
                                        </form>
                                    </td>

                                    @* Cột Trạng thái: Dùng Form riêng *@
                                    <td>
                                        <form asp-action="QuickUpdate" method="post" class="d-inline">
                                            <input type="hidden" name="AppointmentId" value="@item.AppointmentId" />
                                            <select name="Status" class="form-select form-select-sm fw-bold shadow-sm
                                                @(item.Status == "Pending" ? "bg-warning text-dark" :
                                                  item.Status == "Assigned" ? "bg-info text-dark" :
                                                  item.Status == "Completed" ? "bg-success text-white" :
                                                  item.Status == "Cancelled" ? "bg-danger text-white" : "bg-secondary text-white")"
                                                    onchange="this.form.submit()">
                                                <option value="Pending" selected="@(item.Status == "Pending")">⏳ Chờ duyệt</option>
                                                <option value="Assigned" selected="@(item.Status == "Assigned")">👨‍🔧 Đã phân công</option>
                                                <option value="Processing" selected="@(item.Status == "Processing")">🛠 Đang thi công</option>
                                                <option value="Completed" selected="@(item.Status == "Completed")">✅ Hoàn thành</option>
                                                <option value="Cancelled" selected="@(item.Status == "Cancelled")">❌ Đã hủy</option>
                                            </select>
                                        </form>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            @* Nút xem ghi chú: Không phèn nữa! *@
                                            <button type="button" class="btn btn-sm btn-info text-white btn-view-note"
                                                    data-note="@(string.IsNullOrEmpty(item.CustomerNote) ? "Khách hàng không để lại ghi chú." : item.CustomerNote)"
                                                    title="Xem ghi chú">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>

                                            <form asp-action="Delete" asp-route-id="@item.AppointmentId" method="post" class="d-inline">
                                                <button type="button" class="btn btn-sm btn-danger btn-delete-appointment" title="Xóa">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="noteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-comment-dots me-2"></i>Ghi chú khách hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <div id="customerNoteContent" class="fs-6 text-dark lh-base italic"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary px-4 py-2" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // 1. Xem ghi chú qua Modal
            $('.btn-view-note').on('click', function () {
                var note = $(this).data('note');
                $('#customerNoteContent').html('<i class="fa-solid fa-quote-left text-muted me-2"></i>' + note + '<i class="fa-solid fa-quote-right text-muted ms-2"></i>');
                $('#noteModal').modal('show');
            });

            // 2. Xác nhận xóa bằng SweetAlert
            $('.btn-delete-appointment').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: "Thông tin lịch hẹn này sẽ bị xóa vĩnh viễn!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });

            // 3. Thông báo thành công
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: '@Html.Raw(TempData["SuccessMsg"])',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true
                    });
            </text>
        }
        });
    </script>
}