@model WebNoiThatHoaHome.Models.CategoryViewModel
@{
    ViewData["Title"] = "Thêm Danh mục mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-folder-plus text-primary me-2"></i> Thêm Danh mục mới</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên danh mục *</label>
                        <input asp-for="CategoryName" class="form-control" placeholder="VD: Phòng khách, Bàn ăn..." required />
                        <span asp-validation-for="CategoryName" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Mô tả danh mục</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả..."></textarea>
                    </div>

                    <div class="d-flex justify-content-end">
                        <a href="/Admin/Category/Index" class="btn btn-outline-secondary me-2">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary fw-bold"><i class="fa-solid fa-floppy-disk me-1"></i> Lưu danh mục</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>