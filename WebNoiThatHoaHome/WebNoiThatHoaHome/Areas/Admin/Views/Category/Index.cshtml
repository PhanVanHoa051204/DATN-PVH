@model IEnumerable<WebNoiThatHoaHome.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-list text-primary me-2"></i> Danh sách Danh mục</h5>

        <div class="d-flex gap-2">
            <form asp-action="Index" method="get" class="input-group" style="width: 350px;">
                <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Tìm tên danh mục...">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
                {
                    <a href="/Admin/Category/Index" class="btn btn-outline-danger" title="Xóa tìm kiếm">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                }
            </form>
            <a href="/Admin/Category/Create" class="btn btn-primary fw-bold">
                <i class="fa-solid fa-plus me-1"></i> Thêm mới
            </a>
            <a href="/Admin/Category/Trash" class="btn btn-outline-secondary fw-bold">
                <i class="fa-solid fa-trash-can me-1"></i> Thùng rác
            </a>

            
        </div>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="px-4">Mã DM</th>
                    <th>Tên danh mục</th>
                    <th>Mô tả</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="px-4 fw-bold text-muted">#@item.CategoryId</td>
                        <td class="fw-bold text-primary">@item.CategoryName</td>
                        <td>@(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)</td>
                        <td class="text-center">
                            <a href="/Admin/Category/Edit/@item.CategoryId" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@item.CategoryId" method="post" class="d-inline ms-1">
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete" title="Xóa danh mục">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // 1. Xác nhận trước khi Xóa
            $('.btn-delete').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: "Bạn có chắc chắn muốn xóa danh mục này không?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // 2. Bắt TempData báo THÀNH CÔNG từ CategoryController
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: '@Html.Raw(TempData["SuccessMsg"])',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true
                    });
            </text>
        }

            // 3. Bắt TempData báo LỖI từ CategoryController
        @if (TempData["ErrorMsg"] != null)
        {
            <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'error',
                        title: '@Html.Raw(TempData["ErrorMsg"])',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true
                    });
            </text>
        }
        });
    </script>
}