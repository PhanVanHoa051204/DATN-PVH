@model IEnumerable<WebNoiThatHoaHome.Models.ProductListViewModel>
@{
    ViewData["Title"] = "Thùng rác Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-danger"><i class="fa-solid fa-trash-can me-2"></i> Sản phẩm đã xóa (Thùng rác)</h5>
        <a href="/Admin/Product/Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">Mã SP</th>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted">#@item.ProductId</td>
                                <td>
                                    <img src="@item.MainImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;" />
                                </td>
                                <td class="fw-bold">@item.ProductName</td>
                                <td>@item.CategoryName</td>
                                <td class="text-danger">@String.Format("{0:0,0}", item.Price) ₫</td>
                                <td class="text-center">
                                    <a href="/Admin/Product/Restore/@item.ProductId" class="btn btn-sm btn-success"
                                       title="Khôi phục sản phẩm này"
                                       onclick="return confirm('Bạn muốn đưa sản phẩm này quay lại danh sách bán chứ?');">
                                        <i class="fa-solid fa-rotate-left me-1"></i> Khôi phục
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Thùng rác đang trống.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>