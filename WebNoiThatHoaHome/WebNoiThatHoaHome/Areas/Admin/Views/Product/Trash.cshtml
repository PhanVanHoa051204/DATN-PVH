@model IEnumerable<WebNoiThatHoaHome.Models.ProductListViewModel>
@{
    ViewData["Title"] = "Thùng rác Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-danger"><i class="fa-solid fa-trash-can me-2"></i> Sản phẩm đã xóa (Thùng rác)</h5>
        <a href="/Admin/Product/Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">Mã SP</th>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted">#@item.ProductId</td>
                                <td>
                                    <img src="@item.MainImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;" />
                                </td>
                                <td class="fw-bold">@item.ProductName</td>
                                <td>@item.CategoryName</td>
                                <td class="text-danger">@String.Format("{0:0,0}", item.Price) ₫</td>
                                <td class="text-center">
                                    <form asp-action="Restore" asp-route-id="@item.ProductId" method="post" class="d-inline">
                                        <button type="button" class="btn btn-sm btn-success btn-restore" title="Khôi phục">
                                            <i class="fa-solid fa-rotate-left me-1"></i> Khôi phục
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Thùng rác đang trống.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Cảnh báo Xóa
            $('.btn-delete').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: "Sản phẩm này sẽ được chuyển vào thùng rác!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });

            // Cảnh báo Khôi phục
            $('.btn-restore').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Khôi phục sản phẩm?',
                    text: "Sản phẩm sẽ được hiển thị lại trên cửa hàng!",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });

            // Hiện Toast Thành công
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@Html.Raw(TempData["SuccessMsg"])', showConfirmButton: false, timer: 3000 });
            </text>
        }

            // Hiện Toast Lỗi
        @if (TempData["ErrorMsg"] != null)
        {
            <text>
                    Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: '@Html.Raw(TempData["ErrorMsg"])', showConfirmButton: false, timer: 3000 });
            </text>
        }
        });
    </script>
}