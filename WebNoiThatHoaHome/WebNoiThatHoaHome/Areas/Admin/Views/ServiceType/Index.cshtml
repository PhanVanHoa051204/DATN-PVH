@model IEnumerable<WebNoiThatHoaHome.Models.ServiceType>
@{
    ViewData["Title"] = "Quản lý Loại Dịch Vụ";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase mb-0">Quản lý Loại Dịch Vụ</h3>
        <div>
            <a href="/Admin/ServiceType/Trash" class="btn btn-outline-secondary rounded-0 px-3 me-2">
                <i class="fa-solid fa-trash-arrow-up me-1"></i> Thùng rác
            </a>
            <button type="button" class="btn btn-dark rounded-0 px-4" data-bs-toggle="modal" data-bs-target="#addServiceModal">
                <i class="fa-solid fa-plus me-2"></i> Thêm Dịch vụ
            </button>
        </div>
    </div>

    <div class="card rounded-0 border shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Tên Dịch Vụ</th>
                        <th>Giá Cơ Bản</th>
                        <th>Mô tả</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-muted">#@item.ServiceTypeId</td>
                            <td class="fw-bold">@item.TypeName</td>
                            <td class="text-danger fw-bold">
                                @(item.BasePrice.HasValue && item.BasePrice > 0 ? string.Format("{0:N0} ₫", item.BasePrice) : "Miễn phí")
                            </td>
                            <td style="font-size: 13px; max-width: 300px;" class="text-truncate">
                                @item.Description
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-primary rounded-0 me-1" data-bs-toggle="modal" data-bs-target="#editModal-@item.ServiceTypeId" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </button>

                                <form asp-action="Delete" asp-route-id="@item.ServiceTypeId" method="post" class="d-inline form-delete">
                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-0 btn-delete" title="Xóa">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addServiceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-0">
            <div class="modal-header bg-dark text-white rounded-0">
                <h5 class="modal-title"><i class="fa-solid fa-plus"></i> Thêm Loại Dịch Vụ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên dịch vụ <span class="text-danger">*</span></label>
                        <input type="text" name="TypeName" class="form-control rounded-0" placeholder="VD: Đo đạc tại nhà..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Giá cơ bản (VNĐ)</label>
                        <input type="number" name="BasePrice" class="form-control rounded-0" placeholder="Bỏ trống nếu miễn phí" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea name="Description" class="form-control rounded-0" rows="3" placeholder="Ghi chú về dịch vụ..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light rounded-0">
                    <button type="button" class="btn btn-secondary rounded-0" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-dark rounded-0 px-4">Lưu Dữ Liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    <div class="modal fade" id="editModal-@item.ServiceTypeId" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0">
                <div class="modal-header bg-primary text-white rounded-0">
                    <h5 class="modal-title"><i class="fa-solid fa-pen"></i> Chỉnh sửa Dịch vụ #@item.ServiceTypeId</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="ServiceTypeId" value="@item.ServiceTypeId" />
                    <div class="modal-body p-4 text-start">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên dịch vụ <span class="text-danger">*</span></label>
                            <input type="text" name="TypeName" value="@item.TypeName" class="form-control rounded-0" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Giá cơ bản (VNĐ)</label>
                            <input type="number" name="BasePrice" value="@item.BasePrice" class="form-control rounded-0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea name="Description" class="form-control rounded-0" rows="3">@item.Description</textarea>
                        </div>
                    </div>
                    <div class="modal-footer bg-light rounded-0">
                        <button type="button" class="btn btn-secondary rounded-0" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-0 px-4">Lưu Thay Đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}



@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Xác nhận trước khi xóa
            $('.btn-delete').on('click', function (e) {
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Xóa dịch vụ này?',
                    text: "Bạn sẽ không thể khôi phục lại dữ liệu!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Đồng ý Xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit(); // Đồng ý thì mới gửi lệnh xuống Controller
                    }
                });
            });

            // Bắt TempData báo thành công / lỗi
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: '@Html.Raw(TempData["SuccessMsg"])',
                        showConfirmButton: false,
                        timer: 3000
                    });
            </text>
        }

        @if (TempData["ErrorMsg"] != null)
        {
            <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'error',
                        title: '@Html.Raw(TempData["ErrorMsg"])',
                        showConfirmButton: false,
                        timer: 3000
                    });
            </text>
        }
        });
    </script>
}