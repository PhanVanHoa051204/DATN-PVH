@model WebNoiThatHoaHome.Models.Voucher

@{
    ViewData["Title"] = "Thêm mã giảm giá mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">

            <div class="d-flex align-items-center mb-3">
                
                <h4 class="fw-bold m-0">Thêm Mã Giảm Giá Mới</h4>
                
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mã Voucher (Code) <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control form-control-lg border-primary text-danger fw-bold" id="voucherCode" required placeholder="VD: SIEUSALE20, FREESHIP..." />
                            <span asp-validation-for="Code" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <label class="form-label fw-bold">Loại giảm giá</label>
                                <select asp-for="DiscountType" class="form-select">
                                    <option value="Amount">Trừ thẳng tiền mặt (VNĐ)</option>
                                    <option value="Percent">Giảm theo phần trăm (%)</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <label class="form-label fw-bold">Giá trị giảm <span class="text-danger">*</span></label>
                                <input asp-for="DiscountValue" type="number" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Đơn tối thiểu <span class="text-danger">*</span></label>
                                <input asp-for="MinOrderValue" type="number" class="form-control" value="0" required />
                                <small class="text-muted" style="font-size:12px;">Nhập 0 nếu áp dụng mọi đơn</small>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label fw-bold">Ngày bắt đầu <span class="text-danger">*</span></label>
                                <input asp-for="StartDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Ngày kết thúc <span class="text-danger">*</span></label>
                                <input asp-for="EndDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                            </div>
                        </div>

                        <div class="row mb-4 bg-light p-3 rounded-3 border">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label fw-bold">Giới hạn số lượt dùng</label>
                                <input asp-for="UsageLimit" type="number" class="form-control" value="0" />
                                <small class="text-muted" style="font-size:12px;">Nhập 0 nếu muốn khách dùng thoải mái không giới hạn.</small>
                            </div>
                            <div class="col-md-6 d-flex align-items-center">
                                <div class="form-check form-switch fs-5 mt-2">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" id="isActiveSwitch">
                                    <label class="form-check-label fw-bold ms-2 text-success" for="isActiveSwitch">Kích hoạt hoạt động ngay</label>
                                </div>
                            </div>
                        </div>

                        <div class="text-end border-top pt-4">
                            <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
                                <i class="fa-solid fa-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                                <i class="fa-solid fa-floppy-disk me-2"></i> Lưu Voucher
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@section Scripts {
    <script>
        // 1. JS nhỏ giúp tự động viết hoa và xóa khoảng trắng khi Sếp gõ Mã Code
        document.getElementById('voucherCode').addEventListener('input', function (e) {
            this.value = this.value.toUpperCase().replace(/\s/g, '');
        });

        // 2. BẮT LỖI TỪ SERVER VÀ BẮN RA SWEETALERT2
        @if (!ViewData.ModelState.IsValid)
        {
            // Gom tất cả các lỗi (ví dụ: trùng mã) thành một chuỗi
            var errors = ViewData.ModelState.Values
                            .SelectMany(v => v.Errors)
                            .Select(e => e.ErrorMessage)
                            .ToList();
            var errorMessage = string.Join("\\n", errors);

            <text>
                document.addEventListener('DOMContentLoaded', function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Khoan đã Sếp ơi!',
                        text: '@Html.Raw(errorMessage)',
                        confirmButtonText: 'Để tôi sửa lại',
                        confirmButtonColor: '#dc3545'
                    });
                });
            </text>
        }
    </script>
}