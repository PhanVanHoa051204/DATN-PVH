@model WebNoiThatHoaHome.Models.User
@using System.Security.Claims
@inject WebNoiThatHoaHome.Models.HoaHomeDbContext _context

@{
    ViewData["Title"] = "Thanh toán";

    // 1. Lấy ID khách hàng và tính tiền hàng thực tế từ Database
    var userIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
    decimal realSubTotal = 0;

    if (int.TryParse(userIdString, out int userId))
    {
        realSubTotal = _context.CartItems
            .Where(c => c.Cart.UserId == userId)
            .Sum(c => c.Quantity * (c.Product.Price));
    }

    // Phí ship hỏa tốc (Lấy từ ViewBag hoặc đặt cứng nếu chưa có)
    decimal expressFee = ViewBag.ExpressFee ?? 200000;
}

<div class="container my-5">
    <form action="/Checkout/PlaceOrder" method="post" id="checkoutForm">
        <div class="row">
            <div class="col-lg-7 pe-lg-5 mb-4">
                <h5 class="fw-bold mb-4 text-uppercase">Địa chỉ giao hàng</h5>

                <div class="mb-3">
                    <label class="form-label text-muted small">Họ và tên *</label>
                    <input type="text" class="form-control rounded-0" name="CustomerName" value="@Model.FullName" required>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label text-muted small">Số điện thoại *</label>
                        <input type="text" class="form-control rounded-0" name="Phone" value="@Model.Phone" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Địa chỉ email</label>
                        <input type="email" class="form-control rounded-0 bg-light" value="@Model.Email" readonly>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label text-muted small">Tỉnh / Thành phố *</label>
                        <select class="form-select rounded-0" name="City" id="cityDropdown" required>
                            <option value="">Chọn Tỉnh/Thành phố...</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Quận / Huyện *</label>
                        <select class="form-select rounded-0" name="District" id="districtDropdown" required>
                            <option value="">Chọn Quận/Huyện...</option>
                        </select>
                    </div>
                </div>

                <div class="mb-5">
                    <label class="form-label text-muted small">Địa chỉ chi tiết *</label>
                    <input type="text" class="form-control rounded-0" name="AddressDetail" placeholder="Số nhà, tên đường..." required>
                </div>
                
                <h5 class="fw-bold mb-3 text-uppercase">Hình thức giao hàng</h5>
                <div class="border p-3 rounded-0 bg-light mb-4">
                    <div class="form-check mb-2">
                        <input class="form-check-input shipping-method" type="radio" name="ShippingMethod" id="shipStandard" value="Tiêu chuẩn" data-fee="0" checked>
                        <label class="form-check-label d-flex justify-content-between w-100" for="shipStandard">
                            <span>Giao hàng tiêu chuẩn (3-5 ngày)</span>
                            <span class="fw-bold text-success">Miễn phí</span>
                        </label>
                    </div>
                    <hr class="my-2">
                    <div class="form-check">
                        <input class="form-check-input shipping-method" type="radio" name="ShippingMethod" id="shipExpress" value="Hỏa tốc" data-fee="@expressFee">
                        <label class="form-check-label d-flex justify-content-between w-100" for="shipExpress">
                            <span>Giao hàng hỏa tốc (Trong 24h)</span>
                            <span class="fw-bold">@expressFee.ToString("N0") đ</span>
                        </label>
                    </div>
                </div>
                @* @if (User.IsInRole("Admin")) *@
                @* { *@
                @*     <h5 class="fw-bold mt-4 mb-3 text-primary text-uppercase">Chiết khấu trực tiếp (Admin)</h5> *@
                @*     <div class="border border-primary p-3 rounded-0 bg-light mb-4"> *@
                @*         <label class="form-label text-muted small">Nhập số tiền muốn giảm thẳng vào hóa đơn (VNĐ)</label> *@
                @*         <div class="input-group"> *@
                @*             <input type="number" id="DirectDiscount" name="DirectDiscount" class="form-control rounded-0 border-primary" placeholder="Ví dụ: 500000" min="0"> *@
                @*             <button type="button" class="btn btn-primary rounded-0 px-3 fw-bold" onclick="apDungAdminDiscount()">ÁP DỤNG</button> *@
                @*         </div> *@
                @*     </div> *@
                @* } *@
                <h5 class="fw-bold mb-3 text-uppercase">Phương thức thanh toán</h5>
                <div class="border p-3 rounded-0 mb-4">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="paymentCOD" value="COD" checked>
                        <label class="form-check-label" for="paymentCOD">Thanh toán khi nhận hàng (COD)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="paymentVNPAY" value="BANK">
                        <label class="form-check-label" for="paymentVNPAY">Thanh toán qua VNPAY</label>
                    </div>
                </div>
            </div>

            <div class="col-lg-5" style="position: sticky; top: 20px; z-index: 1;">
                <div class="bg-light p-4 border sticky-top" style="top: 100px;">
                    <h5 class="fw-bold mb-4 text-uppercase border-bottom pb-3">Tóm tắt đơn hàng</h5>

                    <div class="mb-4" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var item in Model.Cart.CartItems)
                        {
                            var mainImg = item.Product?.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? "/images/no-image.png";
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="d-flex align-items-center">
                                    <img src="@mainImg" style="width: 50px; height: 50px; object-fit: cover;" class="me-3 border">
                                    <div>
                                        <div class="fw-bold small">@item.Product?.ProductName</div>
                                        <div class="text-muted small">x @item.Quantity</div>
                                    </div>
                                </div>
                                <div class="fw-bold small">@((item.Product?.Price * item.Quantity)?.ToString("N0")) ₫</div>
                            </div>
                        }
                    </div>

                    <div class="voucher-section my-3 p-3 bg-white border">
                        <label class="form-label fw-bold mb-2 small text-uppercase">Mã giảm giá</label>
                        <div class="input-group">
                            <input type="text" id="voucherInput" class="form-control rounded-0" placeholder="Nhập mã...">
                            <button type="button" class="btn btn-dark rounded-0 px-3" onclick="apDungMa()">ÁP DỤNG</button>
                        </div>
                        <div id="voucherMessage" class="mt-2 small"></div>
                    </div>

                    <div class="mt-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính</span>
                            <span class="fw-bold" id="subTotal" data-value="@realSubTotal.ToString("0")">@realSubTotal.ToString("N0") đ</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2 text-success d-none" id="discountRow">
                            <span>Giảm giá</span>
                            <span class="fw-bold" id="discountValue">- 0 đ</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2 text-primary d-none" id="adminDiscountRow">
                            <span>Giảm giá Admin</span>
                            <span class="fw-bold" id="adminDiscountValue">- 0 đ</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Vận chuyển</span>
                            <span class="fw-bold" id="displayShippingFee">0 đ</span>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3 mb-4">
                            <h5 class="fw-bold text-uppercase">Tổng cộng</h5>
                            <h5 class="fw-bold text-danger" id="displayTotal">@realSubTotal.ToString("N0") đ</h5>
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" id="agreeTerms" required>
                        <label class="form-check-label text-muted small" for="agreeTerms">
                            Tôi đồng ý với điều khoản mua hàng của HoaHome.
                        </label>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 py-3 rounded-0 fw-bold fs-5">ĐẶT MUA</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // HÀM TÍNH TỔNG TIỀN (Đã cập nhật thêm Admin Discount)
        function tinhTongCuoiCung() {
            // 1. Tiền hàng gốc từ Database
            var subTotal = parseFloat($('#subTotal').attr('data-value')) || 0;

            // 2. Tiền ship từ radio được chọn
            var shippingFee = parseFloat($('.shipping-method:checked').data('fee')) || 0;

            // 3. Tiền giảm giá Voucher (nếu mở lại)
            var discount = 0;
            if (!$('#discountRow').hasClass('d-none')) {
                var discountText = $('#discountValue').text().replace(/[^0-9]/g, '');
                discount = parseFloat(discountText) || 0;
            }

            // 4. Tiền giảm giá Admin
            var adminDiscountInput = $('#DirectDiscount');
            var adminDiscount = 0;
            if (adminDiscountInput.length > 0) {
                adminDiscount = parseFloat(adminDiscountInput.val()) || 0;
                var totalBeforeAdmin = subTotal + shippingFee - discount;

                // Xử lý bảo mật & trải nghiệm UI
                if (adminDiscount < 0) {
                    adminDiscountInput.val('');
                    adminDiscount = 0;
                } else if (adminDiscount > totalBeforeAdmin) {
                    adminDiscount = totalBeforeAdmin; // Ép về bằng tổng tiền
                    adminDiscountInput.val(adminDiscount);
                }

                if (adminDiscount > 0) {
                    $('#adminDiscountRow').removeClass('d-none');
                    $('#adminDiscountValue').text('- ' + adminDiscount.toLocaleString('vi-VN') + ' đ');
                } else {
                    $('#adminDiscountRow').addClass('d-none');
                }
            }

            // 5. Cập nhật giao diện
            var finalTotal = subTotal + shippingFee - discount - adminDiscount;
            $('#displayShippingFee').text(shippingFee.toLocaleString('vi-VN') + ' đ');
            $('#displayTotal').text(finalTotal.toLocaleString('vi-VN') + ' đ');
        }

        // Gọi hàm này khi Admin bấm nút ÁP DỤNG
        function apDungAdminDiscount() {
            var adminDiscount = parseFloat($('#DirectDiscount').val());
            if (adminDiscount < 0) {
                Swal.fire('Lỗi', 'Số tiền giảm không được âm!', 'error');
            } else {
                tinhTongCuoiCung();
                Swal.fire({
                    toast: true, position: 'top-end', icon: 'success',
                    title: 'Đã cập nhật chiết khấu Admin!',
                    showConfirmButton: false, timer: 1500
                });
            }
        }

        // HÀM ÁP MÃ VOUCHER (Giữ nguyên phòng khi ní cần dùng lại)
        function apDungMa() {
            var code = $('#voucherInput').val().trim();
            var subTotal = parseFloat($('#subTotal').attr('data-value')) || 0;

            if (code === "") {
                Swal.fire('Nhắc nhở', 'Vui lòng nhập mã giảm giá!', 'info');
                return;
            }

            $.ajax({
                url: '/Checkout/CheckVoucher',
                type: 'POST',
                data: { code: code, totalAmount: subTotal },
                success: function (res) {
                    if (res.success) {
                        $('#discountRow').removeClass('d-none');
                        $('#discountValue').text('- ' + res.discountAmount.toLocaleString() + ' đ');
                        tinhTongCuoiCung(); // Tính lại tổng

                        if ($('#appliedVoucherId').length == 0) {
                            $('#checkoutForm').append('<input type="hidden" name="AppliedVoucherId" id="appliedVoucherId" value="' + res.voucherId + '">');
                        } else {
                            $('#appliedVoucherId').val(res.voucherId);
                        }
                        $('#voucherMessage').html('<span class="text-success fw-bold">✓ ' + res.message + '</span>');
                        Swal.fire('Thành công', res.message, 'success');
                    } else {
                        Swal.fire('Lỗi', res.message, 'error');
                        $('#discountRow').addClass('d-none');
                        tinhTongCuoiCung();
                    }
                }
            });
        }

        $(document).ready(function() {
            // Khi đổi ship -> Tính lại tiền ngay (kèm cả tiền Admin giảm)
            $('.shipping-method').on('change', function () {
                tinhTongCuoiCung();
            });

            // Tự động chạy lần đầu để hiện đúng số tiền
            tinhTongCuoiCung();

            // API Tỉnh thành (Giữ nguyên của ní)
            $.ajax({
                url: 'https://provinces.open-api.vn/api/?depth=2',
                method: 'GET',
                success: function(data) {
                    let cityDropdown = $('#cityDropdown');
                    $.each(data, function(index, province) {
                        let option = $('<option></option>').val(province.name).text(province.name);
                        option.data('districts', province.districts);
                        cityDropdown.append(option);
                    });
                }
            });

            $('#cityDropdown').change(function() {
                let districtDropdown = $('#districtDropdown');
                districtDropdown.empty().append('<option value="">Chọn Quận/Huyện...</option>');
                let districts = $(this).find('option:selected').data('districts');
                if (districts) {
                    $.each(districts, function(index, district) {
                        districtDropdown.append($('<option></option>').val(district.name).text(district.name));
                    });
                }
            });
        });
    </script>
}