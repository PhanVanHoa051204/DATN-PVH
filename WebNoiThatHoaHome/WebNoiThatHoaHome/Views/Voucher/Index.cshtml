@model IEnumerable<WebNoiThatHoaHome.Models.Voucher>

@{
    ViewData["Title"] = "Mã Giảm Giá";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase" style="letter-spacing: 1px;">Săn Mã Giảm Giá</h2>
        <p class="text-muted">Lưu lại mã và sử dụng tại bước thanh toán để nhận ưu đãi</p>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <h5 class="text-muted">Hiện tại chưa có mã giảm giá nào. Bạn quay lại sau nhé!</h5>
            </div>
        }

        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-3 mb-4">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 8px; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">

                    <div class="position-relative d-flex justify-content-center align-items-center" style="height: 160px; background: linear-gradient(135deg, #ff7e5f, #feb47b); border-radius: 8px 8px 0 0;">
                        <div class="bg-white px-3 py-2 text-danger fw-bold fs-4" style="border: 2px dashed #ff7e5f; border-radius: 5px; letter-spacing: 2px;">
                            @item.Code
                        </div>
                        <div class="position-absolute w-100 bg-white" style="height: 10px; bottom: -5px; border-radius: 50%; box-shadow: 0 -5px 0 white;"></div>
                    </div>

                    <div class="card-body d-flex flex-column pt-4">
                        <h6 class="card-title fw-bold mb-2">
                            @(item.DiscountType == "Percent" ? $"Giảm {item.DiscountValue}%" : $"Giảm {item.DiscountValue:N0} đ")
                        </h6>

                        <div class="mb-3 text-muted" style="font-size: 0.85rem;">
                            <div class="mb-1"><i class="fa-solid fa-cart-shopping me-1"></i> Đơn tối thiểu: <span class="text-danger fw-bold">@item.MinOrderValue.ToString("N0") đ</span></div>
                            <div class="mb-1"><i class="fa-regular fa-clock me-1"></i> HSD: @item.EndDate.ToString("dd/MM/yyyy")</div>

                            @if (item.UsageLimit > 0)
                            {
                                int remain = item.UsageLimit - item.UsedCount;
                                <div><i class="fa-solid fa-fire text-warning me-1"></i> Chỉ còn <strong>@remain</strong> lượt</div>
                            }
                            else
                            {
                                <div><i class="fa-solid fa-infinity text-primary me-1"></i> Không giới hạn lượt</div>
                            }
                        </div>

                        <button class="btn btn-outline-danger mt-auto w-100 fw-bold" onclick="copyVoucherCode('@item.Code')">
                            SAO CHÉP MÃ
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function copyVoucherCode(code) {
            // Lệnh copy text vào khay nhớ tạm của trình duyệt
            navigator.clipboard.writeText(code).then(function() {
                // Hiển thị thông báo Toast siêu mượt
                Swal.fire({
                    icon: 'success',
                    title: 'Đã lưu mã!',
                    text: 'Mã ' + code + ' đã được copy. Hãy dán vào lúc thanh toán nhé!',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true
                });
            }).catch(function(err) {
                console.error('Không thể copy: ', err);
            });
        }
    </script>
}