@model WebNoiThatHoaHome.Models.ServiceType
@{
    ViewData["Title"] = Model.TypeName;
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy danh sách dịch vụ từ Controller ra
    var allServices = ViewBag.AllServices as List<WebNoiThatHoaHome.Models.ServiceType>;
}

<div class="container my-5">
    <div class="row">

        <div class="col-lg-3 mb-5 mb-lg-0">
            @* Tiêu đề có vạch vàng bên trái giống ảnh Sếp gửi *@
            <h5 class="fw-bold mb-4 border-start border-warning border-3 ps-3">Dịch vụ HoaHome</h5>

            <div class="list-group rounded-0 border-0">
                @if (allServices != null)
                {
                    foreach (var item in allServices.Where(s => !s.TypeName.Contains("Giao hàng")))
                    {
                        // Kiểm tra xem ID dịch vụ trong vòng lặp có trùng với ID đang xem không
                        // Nếu trùng thì bôi đen, làm nổi bật nó lên
                        var isActive = (item.ServiceTypeId == Model.ServiceTypeId) ? "fw-bold text-dark bg-light border-start border-dark border-3" : "text-muted border-0";

                        <a href="/Service/Details/@item.ServiceTypeId" class="list-group-item list-group-item-action py-3 mb-1 @isActive" style="background: transparent;">
                            @item.TypeName
                        </a>
                    }
                }
            </div>
        </div>

        <div class="col-lg-9 ps-lg-5">

            <h3 class="fw-bold mb-4 text-uppercase">@Model.TypeName</h3>

            <div class="bg-light d-flex justify-content-center align-items-center p-5 mb-4 border" style="height: 300px;">
                @if (Model.TypeName.Contains("Đo đạc"))
                {
                    <i class="fa-solid fa-ruler-combined text-primary" style="font-size: 100px; opacity: 0.8;"></i>
                }
                else if (Model.TypeName.Contains("Thiết kế") || Model.TypeName.Contains("Tư vấn"))
                {
                    <i class="fa-solid fa-compass-drafting text-info" style="font-size: 100px; opacity: 0.8;"></i>
                }
                else if (Model.TypeName.Contains("Lắp đặt"))
                {
                    <i class="fa-solid fa-screwdriver-wrench text-warning" style="font-size: 100px; opacity: 0.8;"></i>
                }
                else
                {
                    <i class="fa-solid fa-truck-fast text-success" style="font-size: 100px; opacity: 0.8;"></i>
                }
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label text-muted fw-bold small">GIÁ DỊCH VỤ CƠ BẢN</label>
                    <div class="fs-4 text-danger fw-bold text-uppercase">
                        @if (Model.BasePrice == 0)
                        {
                            <span>Miễn phí</span>
                        }
                        else if (Model.BasePrice > 0)
                        {
                            <span>@string.Format("{0:N0} VNĐ", Model.BasePrice)</span>
                        }
                        else
                        {
                            <span>Liên hệ để nhận báo giá</span>
                        }
                    </div>
                </div>
            </div>

            <div class="mb-5">
                <label class="form-label text-muted fw-bold small">CHI TIẾT DỊCH VỤ</label>
                <div class="lh-lg" style="text-align: justify; font-size: 15px;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Thông tin chi tiết về dịch vụ này đang được cập nhật. Vui lòng liên hệ hotline để biết thêm chi tiết." : Model.Description)
                </div>
            </div>

            <hr class="mb-4" />

            <div class="d-flex gap-3 mt-4">
                <a href="/Appointment/Booking?serviceId=@Model.ServiceTypeId" class="btn btn-dark px-5 py-3 fw-bold rounded-0" style="min-width: 200px;">
                    ĐẶT LỊCH NGAY
                </a>
                @* <a href="tel:0987654321" class="btn btn-outline-dark px-4 py-3 fw-bold rounded-0">
                    GỌI TƯ VẤN
                </a> *@
            </div>
        </div>

    </div>
</div>