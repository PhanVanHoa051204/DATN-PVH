@model WebNoiThatHoaHome.Models.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    .text-shadow-custom {
        text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.8);
    }
</style>

<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/trangchu/banner_phongkhach.jpg" class="d-block w-100 object-fit-cover" style="height: 80vh;" alt="Phòng khách">

            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100" style="top: 0;">
                <h1 class="fw-bold display-4 text-white text-shadow-custom">Chào Mừng Đến Với Nội Thất HoaHome</h1>
                <p class="fs-4 text-white text-shadow-custom mt-2">Khi Không Gian Sống Trở Thành Cảm Hứng</p>
                <a href="/Product" class="btn btn-light rounded-0 px-4 py-2 mt-4 fw-bold text-uppercase" style="letter-spacing: 1px;">Khám phá ngay</a>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/trangchu/banner_phongngu.jpg" class="d-block w-100 object-fit-cover" style="height: 80vh;" alt="Phòng ngủ">

            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100" style="top: 0;">
                <h1 class="fw-bold display-4 text-white text-shadow-custom">Bộ Sưu Tập Tinh Tế</h1>
                <p class="fs-4 text-white text-shadow-custom mt-2">Đánh thức mọi giác quan trong ngôi nhà bạn</p>
                <a href="/Product" class="btn btn-light rounded-0 px-4 py-2 mt-4 fw-bold text-uppercase" style="letter-spacing: 1px;">Xem bộ sưu tập sản phẩm</a>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/trangchu/banner_bep.jpg" class="d-block w-100 object-fit-cover" style="height: 80vh;" alt="Nhà bếp">

            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center h-100" style="top: 0;">
                <h1 class="fw-bold display-4 text-white text-shadow-custom">Hiện Đại & Đẳng Cấp</h1>
                <p class="fs-4 text-white text-shadow-custom mt-2">Kiến tạo không gian hoàn mỹ</p>
                <a href="/Product/NewProducts" class="btn btn-outline-light rounded-0 px-4 py-2 mt-4 fw-bold text-uppercase border-2" style="letter-spacing: 1px;">Sản phẩm mới</a>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<div class="container mt-5">
    <div class="row g-4">
        @if (Model.Categories != null && Model.Categories.Any())
        {
            foreach (var cat in Model.Categories)
            {
                <div class="col-md-4">
                    <a href="/Product/Category/@cat.CategoryId" class="text-decoration-none">
                        <div class="category-block text-center">
                            <div class="img-wrapper mb-3">

                                @if (cat.CategoryName.Contains("Phòng khách", StringComparison.OrdinalIgnoreCase))
                                {
                                    <img src="~/images/trangchu/phong-khach.jpg" alt="@cat.CategoryName" style="width: 100%; height: 350px; object-fit: cover; display: block;">
                                }
                                else if (cat.CategoryName.Contains("Phòng ăn", StringComparison.OrdinalIgnoreCase))
                                {
                                    <img src="~/images/trangchu/phong-an.jpg" alt="@cat.CategoryName" style="width: 100%; height: 350px; object-fit: cover; display: block;">
                                }
                                else if (cat.CategoryName.Contains("Phòng ngủ", StringComparison.OrdinalIgnoreCase))
                                {
                                    <img src="~/images/trangchu/phong-ngu.jpg" alt="@cat.CategoryName" style="width: 100%; height: 350px; object-fit: cover; display: block;">
                                }
                                else
                                {
                                    <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&q=80" alt="@cat.CategoryName" style="width: 100%; height: 350px; object-fit: cover; display: block;">
                                }
                            </div>
                            <h5 class="text-dark fw-bold">@cat.CategoryName</h5>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-4">Chưa có danh mục nào.</div>
        }
    </div>
</div>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2">
        <h3 class="mb-0 fw-bold fs-5 text-uppercase">Sản phẩm mới</h3>

        @* <a href="/Product/NewProducts" class="text-decoration-none text-muted" style="font-size: 13px;">xem tất cả <i class="fa-solid fa-chevron-right fs-6"></i></a> *@
    </div>
    <div class="row g-4">
        @if (Model.NewProducts != null && Model.NewProducts.Any())
        {
            foreach (var item in Model.NewProducts)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="product-card position-relative border-0">

                        <a href="/Product/Details/@item.ProductId" class="d-block text-decoration-none">
                            <img src="@item.MainImageUrl" alt="@item.ProductName" class="img-fluid w-100 object-fit-cover" style="height: 250px;">
                        </a>

                        <a href="/Product/Details/@item.ProductId" class="text-decoration-none text-dark d-block mt-3 px-2">
                            <h6 class="product-title mb-2 fw-bold" style="font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @item.ProductName
                            </h6>
                        </a>

                        <div class="d-flex justify-content-between align-items-center mt-2 px-2 pb-3">
                            <div class="product-price text-danger fw-bold">
                                @String.Format("{0:0,0}", item.Price) đ
                            </div>

                            <button type="button" class="btn btn-link text-dark p-0 btn-wishlist position-relative" data-product-id="@item.ProductId" style="font-size: 20px; text-decoration: none; z-index: 10;">
                                <i class="fa-regular fa-heart heart-icon-@item.ProductId"></i>
                            </button>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="fa-solid fa-box-open fa-3x mb-3 text-light"></i>
                <p>Chưa có sản phẩm nào được đăng bán.</p>
            </div>
        }
    </div>
</div>

<footer class="footer-dark mt-5 pt-5 pb-3" style="background-color: #212529;">
