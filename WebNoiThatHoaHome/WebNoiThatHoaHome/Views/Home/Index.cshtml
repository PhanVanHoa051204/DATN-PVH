        <div class="row">
            <div class="col-md-3 mb-4">
                <h6 class="text-uppercase mb-4 text-white">Kết nối với HoaHome</h6>
                <h2 class="text-white border border-white d-inline-block p-2 mb-4" style="letter-spacing: 2px;">HOAHOME</h2>
                <p class="text-muted" style="font-size: 13px;">FOLLOW US<br>Instagram - Youtube - Facebook</p>
                <a href="#" class="btn btn-outline-light rounded-0 mt-2 text-uppercase" style="font-size: 12px; letter-spacing: 1px;">Hệ thống cửa hàng</a>
            </div>

            <div class="col-md-3 mb-4">
                <h6 class="text-uppercase mb-4 text-white">HoaHome</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Giới thiệu</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Chuyện HoaHome</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Tổng công ty</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Tuyển dụng</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Thẻ hội viên</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Đổi trả hàng</a></li>
                </ul>
            </div>

            <div class="col-md-3 mb-4">
                <h6 class="text-uppercase mb-4 text-white">Cảm hứng #HoaHome</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Sản phẩm</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Ý tưởng và cảm hứng</a></li>
                </ul>
            </div>

            <div class="col-md-3 mb-4">
                <h6 class="text-uppercase mb-4 text-white">Newsletter</h6>
                <p style="font-size: 13px; color: #bbb; line-height: 1.8;">Hãy để lại email của bạn để nhận được những ý tưởng trang trí mới và những thông tin, ưu đãi từ HoaHome</p>
                <p style="font-size: 13px; color: #bbb;">Email: info@hoahome.com.vn<br>Hotline: 0345 033 641</p>

                <form class="input-group mt-3">
                    <input type="email" class="form-control rounded-0 bg-secondary border-0 text-white" placeholder="Nhập email của bạn" style="font-size: 13px;">
                    <button class="btn btn-light rounded-0 text-uppercase fw-bold" type="submit" style="font-size: 13px; letter-spacing: 1px;">Đăng ký</button>
                </form>
            </div>
        </div>
    </div>
</footer>