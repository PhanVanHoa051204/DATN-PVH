@model IEnumerable<WebNoiThatHoaHome.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <h5 class="fw-bold mb-4 ps-3 border-start border-dark border-3">Tài khoản cá nhân</h5>
            <div class="list-group list-group-flush rounded-0">
                <a href="/Account/Profile" class="list-group-item list-group-item-action border-0 py-2">Thông tin của tôi</a>
                <a href="/Account/Orders" class="list-group-item list-group-item-action border-0 fw-bold py-2">Đơn hàng của tôi</a>
                <a href="/Account/Appointments" class="list-group-item list-group-item-action border-0 py-2">Lịch hẹn của tôi</a>
                <a href="/Account/Wishlist" class="list-group-item list-group-item-action border-0 py-2">Danh sách yêu thích</a>
                <a href="/Account/Logout" class="list-group-item list-group-item-action border-0 py-2 text-danger">Đăng xuất</a>
            </div>
        </div>

        <div class="col-md-9 ps-md-5">
            <h5 class="fw-bold mb-4 text-uppercase">Đơn hàng của tôi</h5>

            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-light border">
                    <i class="fa-solid fa-box-open text-muted mb-3" style="font-size: 3rem;"></i>
                    <p class="text-muted">Bạn chưa có đơn hàng nào.</p>
                    <a href="/Product/Index" class="btn btn-dark rounded-0 px-4 mt-2">MUA SẮM NGAY</a>
                </div>
            }
            else
            {
                <div class="accordion" id="accordionOrders">
                    @foreach (var order in Model)
                    {
                        string collapseId = "collapseOrder" + order.OrderId;
                        string headingId = "headingOrder" + order.OrderId;

                        <div class="accordion-item rounded-0 mb-3 border">
                            <h2 class="accordion-header" id="@headingId">
                                <button class="accordion-button collapsed bg-white rounded-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                    <div class="d-flex w-100 justify-content-between align-items-center pe-3">
                                        <div>
                                            <span class="fw-bold text-dark">Đơn hàng #@order.OrderId</span>
                                            <small class="text-muted ms-2">| Đặt ngày: @order.OrderDate?.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="fw-bold text-danger d-block">@string.Format("{0:N0} ₫", order.TotalAmount)</span>
                                            <span class="badge bg-dark rounded-0 mt-1">@TranslateOrderStatus(order.OrderStatus)</span>
                                        </div>
                                    </div>
                                </button>
                            </h2>

                            <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#accordionOrders">
                                <div class="accordion-body bg-light">
                                    <div class="row mb-3 pb-3 border-bottom" style="font-size: 13px;">
                                        <div class="col-md-6">
                                            <span class="text-muted fw-bold d-block mb-1">Địa chỉ giao hàng:</span>
                                            <span>@order.ShippingAddress</span>
                                        </div>
                                        <div class="col-md-6 mt-2 mt-md-0">
                                            <span class="text-muted fw-bold d-block mb-1">Thanh toán:</span>
                                            <span>@(order.PaymentMethod == "BANK" ? "Chuyển khoản (VNPay)" : "Thanh toán khi nhận hàng (COD)")</span>
                                            <br />
                                            <span class="text-muted">Trạng thái TT: </span>
                                            <span class="fw-bold @(order.PaymentStatus == "Success" ? "text-success" : "text-warning")">@TranslatePaymentStatus(order.PaymentStatus)</span>
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-borderless align-middle mb-0">
                                            <tbody>
                                                @foreach (var item in order.OrderItems)
                                                {
                                                    var img = item.Product?.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? "/images/no-image.png";
                                                    <tr>
                                                        <td style="width: 60px;"><img src="@img" style="width: 50px; height: 50px; object-fit: cover;" class="border"></td>
                                                        <td><a href="/Product/Details/@item.ProductId" class="text-dark text-decoration-none fw-bold" style="font-size: 13px;">@item.Product?.ProductName</a></td>
                                                        <td class="text-center text-muted" style="font-size: 13px;">SL: @item.Quantity</td>
                                                        <td class="text-end fw-bold" style="font-size: 13px;">@string.Format("{0:N0} ₫", item.UnitPrice * item.Quantity)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="mt-3 border-top pt-3 d-flex justify-content-between align-items-center">
                                        <strong>Tổng tiền: <span class="text-danger">@string.Format("{0:N0} ₫", order.TotalAmount)</span></strong>

                                        @if (order.OrderStatus == "New" || order.OrderStatus == "Processing")
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm rounded-0" data-bs-toggle="modal" data-bs-target="#modalCancel-@order.OrderId">
                                                <i class="fa-solid fa-xmark me-1"></i> Yêu cầu hủy đơn
                                            </button>

                                            <div class="modal fade" id="modalCancel-@order.OrderId" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content border-0 shadow rounded-0">
                                                        <div class="modal-header bg-danger text-white rounded-0">
                                                            <h5 class="modal-title fw-bold">Hủy đơn hàng #@order.OrderId</h5>
                                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        @* Tìm dòng này và sửa asp-controller *@
                                                        <form asp-action="RequestCancel" asp-controller="Account" method="post">
                                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                                            <div class="modal-body text-start">
                                                                <label class="form-label fw-bold">Lý do hủy đơn:</label>
                                                                <textarea name="reason" class="form-control" rows="3" required></textarea>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="submit" class="btn btn-danger">Gửi yêu cầu</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else if (order.OrderStatus == "PendingCancel")
                                        {
                                            <span class="badge bg-warning text-dark py-2 px-3 rounded-0">Đang chờ duyệt hủy</span>
                                        }
                                    </div>

                                    @if (!string.IsNullOrEmpty(order.CustomerNote))
                                    {
                                        <div class="alert alert-info mt-3 mb-0 rounded-0 border-0 border-start border-info border-4" style="font-size: 13px;">
                                            <strong class="text-dark"><i class="fa-solid fa-envelope-open-text text-info me-2"></i> Thông tin ghi chú & Phản hồi:</strong>
                                            <div class="mt-2" style="line-height: 1.6;">
                                                @{
                                                    // 1. Lấy dữ liệu thô và thay thế các từ khóa cho thân thiện với khách
                                                    var rawNote = order.CustomerNote ?? "";
                                                    var friendlyNote = rawNote.Replace("[Phản hồi Admin]:", "[Shop trả lời]:")
                                                    .Replace("[Phản hồi từ Admin]:", "[Shop trả lời]:")
                                                    .Replace("[Phản hồi từ Shop]:", "[Shop trả lời]:");

                                                    // 2. Tự động thêm dấu phân tách | trước mỗi dấu [
                                                    var formattedNote = friendlyNote.Replace("[", "|[");

                                                    // 3. Tách thành các mảng dựa trên dấu |
                                                    var parts = formattedNote.Split('|', StringSplitOptions.RemoveEmptyEntries);
                                                }

                                                @foreach (var p in parts)
                                                {
                                                    @* Kiểm tra nếu là dòng của Shop trả lời thì cho chữ đậm hơn hoặc đổi màu *@
                                                    if (p.Contains("[Shop trả lời]:"))
                                                    {
                                                        <p class="mb-1 text-primary fw-bold">@p.Trim()</p>
                                                    }
                                                    else
                                                    {
                                                        <p class="mb-1 text-muted">@p.Trim()</p>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    public string TranslateOrderStatus(string status)
    {
        switch (status)
        {
            case "New": return "Chờ xác nhận";
            case "Processing": return "Đang xử lý";
            case "Delivering": return "Đang giao hàng";
            case "Completed": return "Đã hoàn thành";
            case "Cancelled": return "Đã hủy";
            case "PendingCancel": return "Chờ duyệt hủy";
            default: return status;
        }
    }
    public string TranslatePaymentStatus(string status)
    {
        switch (status)
        {
            case "Pending": return "Chờ thanh toán";
            case "Success": return "Đã thanh toán";
            case "Failed": return "Lỗi thanh toán";
            default: return status;
        }
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@Html.Raw(TempData["SuccessMsg"])', showConfirmButton: false, timer: 3000 });
            </text>
        }
        @if (TempData["ErrorMsg"] != null)
        {
            <text>
                    Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: '@Html.Raw(TempData["ErrorMsg"])', showConfirmButton: false, timer: 3000 });
            </text>
        }
        });
    </script>
}