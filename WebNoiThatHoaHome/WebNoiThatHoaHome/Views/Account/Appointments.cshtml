@model IEnumerable<WebNoiThatHoaHome.Models.Appointment>
@{
    ViewData["Title"] = "Lịch hẹn của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Dùng layout gốc của trang khách
}

<div class="container my-5">
    <div class="row">

        <div class="col-lg-3 mb-5 mb-lg-0">
            <h5 class="fw-bold mb-4 border-start border-warning border-3 ps-3">Tài khoản cá nhân</h5>

            <div class="list-group list-group-flush rounded-0">
                <a href="/Account/Profile" class="list-group-item list-group-item-action border-0 py-2">Thông tin của tôi</a>
                <a href="/Account/Orders" class="list-group-item list-group-item-action border-0 py-2">Đơn hàng của tôi</a>
                <a href="/Account/Appointments" class="list-group-item list-group-item-action border-0 fw-bold py-2">Lịch hẹn của tôi</a>
                <a href="/Account/MyReviews" class="list-group-item list-group-item-action border-0">Đánh giá sản phẩm</a>
                <a href="/Account/Wishlist" class="list-group-item list-group-item-action border-0 py-2">Danh sách yêu thích</a>
                <a href="/Account/Logout" class="list-group-item list-group-item-action border-0 py-2 text-danger">Đăng xuất</a>
            </div>
        </div>

        <div class="col-lg-9 ps-lg-5">
            <h5 class="fw-bold mb-4 text-uppercase">LỊCH HẸN CỦA TÔI</h5>

            <div class="list-group rounded-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="list-group-item py-4 border-start-0 border-end-0 border-top-0 border-bottom">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold me-2">Lịch hẹn #@item.AppointmentId</span>
                                    <span class="text-muted small">| Đặt lúc: @item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>

                                    <div class="mt-2">
                                        <span class="text-dark fw-bold"><i class="fa-solid fa-briefcase text-secondary me-2"></i>@item.ServiceType?.TypeName</span>
                                    </div>
                                    <div class="mt-1 text-muted small">
                                        <i class="fa-regular fa-clock me-2"></i>Thời gian mong muốn: <strong class="text-danger">@item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</strong>
                                    </div>
                                </div>

                                <div class="text-end">
                                    <span class="badge @GetAppStatusColor(item.Status) px-3 py-2 d-inline-block mb-1">
                                        @TranslateAppStatus(item.Status)
                                    </span>

                                    @if (item.Status == "Pending")
                                    {
                                        <form asp-action="Cancel" asp-controller="Appointment" asp-route-id="@item.AppointmentId" method="post">
                                            <button type="submit" class="btn btn-link text-danger text-decoration-none p-0 small btn-cancel-appointment">
                                                <i class="fa-solid fa-xmark me-1"></i> Hủy lịch này
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-regular fa-calendar-xmark fa-3x mb-3 text-light"></i>
                        <p>Bạn chưa đặt lịch dịch vụ nào.</p>
                        <a href="/Appointment/Booking" class="btn btn-dark rounded-0 px-4 py-2 mt-2">ĐẶT LỊCH NGAY</a>
                    </div>
                }
            </div>
        </div>

    </div>
</div>
@functions {
    // Dịch chữ
    public string TranslateAppStatus(string status)
    {
        if (string.IsNullOrEmpty(status)) return "Chờ duyệt";
        switch (status)
        {
            case "Pending": return "Chờ duyệt";
            case "Assigned": return "Đã phân công";
            case "InProgress":
            case "Processing": return "Đang thi công";
            case "Completed": return "Hoàn thành";
            case "Cancelled": return "Đã hủy";
            default: return status;
        }
    }

    // Gán màu cho Badge
    public string GetAppStatusColor(string status)
    {
        if (string.IsNullOrEmpty(status)) return "bg-secondary";
        switch (status)
        {
            case "Pending": return "bg-secondary";
            case "Assigned": return "bg-info text-dark"; // Màu xanh lơ cho Đã phân công
            case "InProgress":
            case "Processing": return "bg-primary";
            case "Completed": return "bg-success";
            case "Cancelled": return "bg-danger";
            default: return "bg-dark";
        }
    }
}
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // 1. Xử lý nút Hủy
            $('.btn-cancel-appointment').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');

                Swal.fire({
                    title: 'Bạn muốn hủy lịch hẹn?',
                    text: "Hành động này không thể hoàn tác!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý hủy',
                    cancelButtonText: 'Quay lại'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // 2. Hiện thông báo Toast từ TempData (nếu có)
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: '@Html.Raw(TempData["SuccessMsg"])',
                            showConfirmButton: false,
                            timer: 3000
                        });
            </text>
        }
        });
    </script>
}