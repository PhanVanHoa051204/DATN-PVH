<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HoaHome</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebNoiThatHoaHome.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="top-bar d-none d-md-block">
        <div class="container-fluid px-5 d-flex justify-content-between">
            <div>
                <span class="me-3"><i class="fa-solid fa-flag text-danger"></i> VN EN</span>
                <span><i class="fa-solid fa-phone"></i> <strong>0903 884 358</strong></span>
                <a href="#" class="text-dark text-decoration-none ms-3">Giới thiệu</a>
                <a href="#" class="text-dark text-decoration-none ms-3">Khuyến mãi</a>
                <a href="#" class="text-danger text-decoration-none ms-3 fw-bold">Giảm giá đặc biệt</a>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container-fluid px-5">
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="fa-solid fa-bars fs-3"></i>
            </button>
            <a class="navbar-brand border border-dark px-3 py-1 me-4" href="/">HoaHome</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="#">Sản phẩm mới</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Sản phẩm <i class="fa-solid fa-chevron-down ms-1" style="font-size:10px;"></i></a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Phòng <i class="fa-solid fa-chevron-down ms-1" style="font-size:10px;"></i></a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Bộ sưu tập</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Thiết kế nội thất</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <div class="input-group me-4" style="width: 250px;">
                        <input type="text" class="form-control rounded-pill bg-light border-0 px-3" placeholder="Tìm sản phẩm">
                        <span class="input-group-text bg-light border-0 rounded-pill"><i class="fa-solid fa-magnifying-glass"></i></span>
                    </div>
                    <div class="nav-icons d-flex align-items-center">
                        <a href="#"><i class="fa-solid fa-location-dot"></i></a>
                        <a href="#"><i class="fa-regular fa-heart"></i></a>
                        <a href="#"><i class="fa-solid fa-bag-shopping"></i></a>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown ms-3">
                                <a href="#" class="text-dark text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" style="font-size: 13px;">Xin chào, @User.Identity.Name</a>
                                <ul class="dropdown-menu dropdown-menu-end rounded-0">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" href="/Admin/Home/Index">Trang Quản trị</a></li>
                                    }
                                    <li><a class="dropdown-item" href="#">Đơn hàng của tôi</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="/Account/Logout">Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="#" class="ms-3 text-dark text-decoration-none d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#authModal" style="font-size: 13px;">
                                Đăng nhập <i class="fa-regular fa-user ms-1"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main role="main">@RenderBody()</main>

    <div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 rounded-0">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close" style="z-index: 1060;"></button>
                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-md-6 p-5 border-end">
                            <h4 class="modal-title-custom mb-4">Đăng nhập</h4>

                            @* Chỉ hiện lỗi nếu Route đang là Login *@
                            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Login")
                            {
                                <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                            }

                            <form asp-controller="Account" asp-action="Login" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Địa chỉ email *</label>
                                    <input type="email" name="Email" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu *</label>
                                    <input type="password" name="Password" class="form-control" required>
                                </div>
                                <button type="submit" class="btn-black w-100">Đăng nhập</button>
                            </form>
                        </div>

                        <div class="col-md-6 p-5">
                            <h4 class="modal-title-custom mb-4">Đăng ký</h4>

                            @* Chỉ hiện lỗi nếu Route đang là Register *@
                            @if (ViewContext.RouteData.Values["action"]?.ToString() == "Register")
                            {
                                <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                            }

                            <form asp-controller="Account" asp-action="Register" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Họ và tên *</label>
                                    <input type="text" name="FullName" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Địa chỉ email *</label>
                                    <input type="email" name="Email" class="form-control" required>
                                </div>
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <label class="form-label">Mật khẩu *</label>
                                        <input type="password" name="Password" class="form-control" required>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Xác nhận *</label>
                                        <input type="password" name="ConfirmPassword" class="form-control" required>
                                    </div>
                                </div>
                                <button type="submit" class="btn-black w-100">Đăng ký</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var modalElement = document.getElementById('authModal');
            if(!modalElement) return;
            var myModal = new bootstrap.Modal(modalElement);

        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                        alert("@Html.Raw(TempData["SuccessMsg"])");
                        myModal.show();
            </text>
        }
        else if (!ViewData.ModelState.IsValid)
        {
            <text>myModal.show();</text>
        }
        });
    </script>
</body>
</html>