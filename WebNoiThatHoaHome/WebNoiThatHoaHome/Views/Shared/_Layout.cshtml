@using Microsoft.EntityFrameworkCore
@using WebNoiThatHoaHome.Models
@inject HoaHomeDbContext _context
@using System.Security.Claims
@inject WebNoiThatHoaHome.Models.HoaHomeDbContext _context
@{
    // Lấy danh sách dịch vụ từ DB ra biến serviceCategories
    var serviceCategories = await _context.ServiceTypes
        .Where(s => s.IsDeleted != true)
        .ToListAsync();
}
@{
    // Biến lưu tổng số lượng hàng trong giỏ
    int cartCount = 0;

    // Nếu khách đã đăng nhập, tìm giỏ hàng của họ và cộng dồn số lượng lại
    if (User.Identity.IsAuthenticated)
    {
        var userIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(userIdString, out int userId))
        {
            // Sum(c => c.Quantity) sẽ cộng tất cả số lượng của các món lại
            // Ví dụ: 2 ghế + 1 bàn = hiện số 3
            cartCount = _context.CartItems.Where(c => c.Cart.UserId == userId).Sum(c => c.Quantity);
        }
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HoaHome</title>
    <link rel="icon" type="image/jpg" href="~/images/favicon.jpg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebNoiThatHoaHome.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="top-bar d-none d-md-block">
        <div class="container-fluid px-5 d-flex justify-content-between">
            <div>
                <span class="me-3"><i class="fa-solid fa-flag text-danger"></i> VN </span>
                <span><i class="fa-solid fa-phone"></i> <strong>0345 033 641</strong></span>
                <a href="#" class="text-dark text-decoration-none ms-3">Giới thiệu</a>
                
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container-fluid px-5">
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="fa-solid fa-bars fs-3"></i>
            </button>
            <a class="navbar-brand border border-dark px-3 py-1 me-4" href="/">HoaHome</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.Value.Contains("/Product/NewProducts") ? "active fw-bold text-danger" : "")"
                           href="@Url.Action("NewProducts", "Product")">
                            SẢN PHẨM MỚI
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link text-uppercase @(Context.Request.Path.Value.Contains("/Product/Index") ? "active fw-bold text-danger" : "")"
                           href="/Product/Index">
                            TẤT CẢ SẢN PHẨM
                        </a>
                    </li>
                    @{
                        // Lấy toàn bộ danh mục đang có trong Database (chưa bị xóa)
                        var roomCategories = _context.Categories.Where(c => c.IsDeleted == false).ToList();

                        // Lấy danh mục đầu tiên (thường ID số 1 của bạn đang là Phòng khách)
                        var defaultCategory = roomCategories.FirstOrDefault();
                    }

                    <li class="nav-item dropdown">
                        <a class="nav-link text-uppercase fw-bold" href="@(defaultCategory != null ? $"/Product/Category/{defaultCategory.CategoryId}" : "#")" id="navbarRooms" data-bs-toggle="dropdown">
                            Phòng <i class="fa-solid fa-chevron-down ms-1" style="font-size: 10px;"></i>
                        </a>

                        <ul class="dropdown-menu shadow border-0 mt-0">
                            @if (roomCategories.Any())
                            {
                                foreach (var cat in roomCategories)
                                {
                                    // Logic chọn Icon dựa trên tên danh mục (Sếp có thể thêm bớt tùy tên DB của Sếp)
                                    string iconClass = "fa-door-open text-secondary"; // Mặc định
                                    string iconColor = "text-secondary";

                                    if (cat.CategoryName.Contains("Khách")) { iconClass = "fa-couch"; iconColor = "text-primary"; }
                                    else if (cat.CategoryName.Contains("Ăn")) { iconClass = "fa-utensils"; iconColor = "text-warning"; }
                                    else if (cat.CategoryName.Contains("Ngủ")) { iconClass = "fa-bed"; iconColor = "text-info"; }
                                    else if (cat.CategoryName.Contains("Việc")) { iconClass = "fa-desktop"; iconColor = "text-secondary"; }
                                    else if (cat.CategoryName.Contains("Bếp")) { iconClass = "fa-kitchen-set"; iconColor = "text-danger"; }
                                    else if (cat.CategoryName.Contains("Trang trí")) { iconClass = "fa-shapes"; iconColor = "text-dark"; }
                                    else if (cat.CategoryName.Contains("Ngoại")) { iconClass = "fa-tree"; iconColor = "text-success"; }

                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center" href="/Product/Category/@cat.CategoryId">
                                            <i class="fa-solid @iconClass @iconColor me-3" style="width: 20px; text-align: center;"></i>
                                            <span>@cat.CategoryName</span>
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item py-2 text-muted">Chưa có danh mục</span></li>
                            }
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link text-danger fw-bold" href="@Url.Action("Index", "Voucher")">
                            <i class="fa-solid fa-ticket-simple me-1"></i> LẤY MÃ GIẢM GIÁ
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-uppercase" href="#" id="navbarServices" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Dịch vụ
                        </a>
                        <ul class="dropdown-menu shadow border-0 mt-0">
                            
                            @if (serviceCategories != null && serviceCategories.Any())
                            {
                                foreach (var svc in serviceCategories.Where(s => !s.TypeName.Contains("Giao hàng")))
                                {
                                    // Logic gán Icon dựa trên TypeName của bảng ServiceType
                                    string svcIcon = "fa-gear"; // Mặc định
                                    string svcColor = "text-secondary";

                                    if (svc.TypeName.Contains("Đo đạc")) { svcIcon = "fa-ruler-combined"; svcColor = "text-primary"; }
                                    else if (svc.TypeName.Contains("Thiết kế") || svc.TypeName.Contains("Tư vấn")) { svcIcon = "fa-compass-drafting"; svcColor = "text-info"; }
                                    else if (svc.TypeName.Contains("Lắp đặt")) { svcIcon = "fa-screwdriver-wrench"; svcColor = "text-warning"; }
                                    
                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center" href="/Service/Details/@svc.ServiceTypeId">
                                            <i class="fa-solid @svcIcon @svcColor me-3" style="width: 20px; text-align: center;"></i>
                                            <span>@svc.TypeName</span>
                                        </a>
                                    </li>
                                }
                                
                            }
                            else
                            {
                                <li><span class="dropdown-item py-2 text-muted">Đang cập nhật dịch vụ...</span></li>
                            }
                        </ul>
                    </li>
                </ul>
                <div class="d-flex align-items-center">
                    <div class="input-group me-4" style="width: 250px;">
                        <form action="/Product/Search" method="get" class="input-group me-4" style="width: 250px;">
                            <input type="text" name="keyword" class="form-control rounded-pill bg-light border-0 px-3"
                                   placeholder="Tìm sản phẩm" value="@Context.Request.Query["keyword"]" required>

                            <button type="submit" class="input-group-text bg-light border-0 rounded-pill">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </button>
                        </form>
                    </div>
                    <div class="nav-icons d-flex align-items-center">
                        <a href="#"><i class="fa-solid fa-location-dot"></i></a>
                        <a href="/Account/Wishlist" class="nav-link text-dark position-relative me-3">
                            <i class="fa-regular fa-heart fs-5"></i>
                            <span id="wishlist-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 10px;">
                                0
                            </span>
                        </a>
                        <a href="/Cart/Index" class="text-dark me-3 position-relative" style="font-size: 18px;" title="Giỏ hàng của tôi">
                            <i class="fa-solid fa-bag-shopping"></i>

                            <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 10px;">
                                @cartCount
                            </span>
                        </a>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown ms-3">
                                <a href="#" class="text-dark text-decoration-none dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown" style="font-size: 14px;">
                                    Tài khoản của tôi <i class="fa-solid fa-user ms-2" style="font-size: 16px;"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end rounded-0 border-0 shadow-sm mt-3" style="width: 220px;">
                                    <li><a class="dropdown-item py-2 text-muted" href="/Account/Profile">Thông tin của tôi</a></li>
                                    <li><a class="dropdown-item py-2 text-muted" href="/Account/Orders">Đơn hàng</a></li>
                                    <li><a class="dropdown-item py-2 text-muted" href="/Account/Appointments">Lịch hẹn của tôi</a></li>
                                    <li><a class="dropdown-item py-2 text-muted" href="/Account/Wishlist">Danh sách yêu thích</a></li>
                                    
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item py-2 text-dark fw-bold" href="/Admin/Home/Index">Trang Quản trị</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-dark" href="/Account/Logout">Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="#" class="ms-3 text-dark text-decoration-none d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#authModal" style="font-size: 13px;">
                                Đăng nhập <i class="fa-regular fa-user ms-1"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main role="main">@RenderBody()</main>

    <div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 rounded-0">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close" style="z-index: 1060;"></button>

                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-md-6 p-5 border-end">
                            <h4 class="modal-title-custom mb-4">Đăng nhập</h4>
                            <form asp-controller="Account" asp-action="Login" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Địa chỉ email *</label>
                                    <input type="email" name="Email" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu *</label>
                                    <input type="password" name="Password" class="form-control" required>
                                </div>
                                <button type="submit" class="btn btn-dark text-white w-100">ĐĂNG NHẬP</button>

                                @if (TempData["LoginError"] != null)
                                {
                                    string loginErr = TempData["LoginError"].ToString();
                                    TempData.Remove("LoginError"); 
                                    <p class="text-danger text-center mt-2 mb-0 fw-bold error-trigger" style="font-size: 14px;">
                                        <i class="fa-solid fa-circle-exclamation"></i> @loginErr
                                    </p>
                                }
                            </form>
                        </div>

                        <div class="col-md-6 p-5">
                            <h4 class="modal-title-custom mb-4">Đăng ký</h4>
                            <form asp-controller="Account" asp-action="Register" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Họ và tên *</label>
                                    <input type="text" name="FullName" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Địa chỉ email *</label>
                                    <input type="email" name="Email" class="form-control" required>
                                </div>
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <label class="form-label">Mật khẩu *</label>
                                        <input type="password" name="Password" class="form-control" required>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Xác nhận *</label>
                                        <input type="password" name="ConfirmPassword" class="form-control" required>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-dark text-white w-100">ĐĂNG KÝ</button>

                                @if (TempData["RegisterError"] != null)
                                {
                                    string regErr = TempData["RegisterError"].ToString();
                                    TempData.Remove("RegisterError"); 
                                    <p class="text-danger text-center mt-2 mb-0 fw-bold error-trigger" style="font-size: 14px;">
                                        <i class="fa-solid fa-circle-exclamation"></i> @regErr
                                    </p>
                                }
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalElement = document.getElementById('authModal');
            if (!modalElement) return;

            // Cài đặt modal
            var authModal = new bootstrap.Modal(modalElement);

            // NẾU CÓ CHỮ ĐỎ THÌ MỚI BẬT LÊN
            var hasError = document.querySelector('.error-trigger') !== null;
            if (hasError) {
                authModal.show();
            }

            // BÁO TOAST THÀNH CÔNG (Nếu có)
        @if (TempData["SuccessMsg"] != null)
        {
            <text>
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: '@Html.Raw(TempData["SuccessMsg"])',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true
                    });
            </text>
        }
        });
    </script>

    <script>
        $(document).ready(function () {
            $.ajax({
                url: '/Wishlist/GetWishlistCount',
                type: 'GET',
                success: function (count) {
                    // Lấy con số từ Controller đắp vào cục màu đỏ
                    $('#wishlist-count').text(count);
                }
            });
        });
        function toggleWishlist(productId) {
            $.ajax({
                url: '/Wishlist/ToggleWishlist',
                type: 'POST',
                data: { id: productId },
                success: function (res) {
                    if (res.success) {
                        // 1. CẬP NHẬT SỐ LƯỢNG TRÊN CỤC ĐỎ
                        $('#wishlist-count').text(res.totalCount);

                        // 2. HIỆN THÔNG BÁO & ĐỔI MÀU TIM
                        if (res.isAdded) {
                            // Thêm tim: Tim đặc, màu đỏ
                            $('.heart-icon-' + productId).removeClass('fa-regular').addClass('fa-solid text-danger');

                            // Thông báo mượt mà góc màn hình
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'success',
                                title: 'Đã thêm vào danh sách yêu thích',
                                showConfirmButton: false,
                                timer: 2000
                                
                            });
                        } else {
                            // Bỏ tim: Tim rỗng, viền đen
                            $('.heart-icon-' + productId).removeClass('fa-solid text-danger').addClass('fa-regular');

                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'info',
                                title: 'Đã bỏ khỏi danh sách yêu thích',
                                showConfirmButton: false,
                                timer: 2000
                                
                            });
                        }
                    } else {
                        // Chưa đăng nhập thì đá về trang Login
                        if (res.message === "Not logged in") {
                            window.location.href = '/Account/Login';
                        }
                    }
                },
                error: function () {
                    alert('Có lỗi xảy ra, vui lòng thử lại!');
                }
            });
        }
    </script>
    
</body>
</html>