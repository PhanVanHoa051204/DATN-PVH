@model WebNoiThatHoaHome.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
    // Lấy ảnh chính, nếu không có thì lấy ảnh mặc định
    var mainImage = Model.ProductImages.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? "/images/no-image.png";
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb" style="font-size: 13px;">
            <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Product/Category/@Model.CategoryId" class="text-dark text-decoration-none">@Model.Category?.CategoryName</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-7 mb-4">
            <div class="row">
                <div class="col-2 d-none d-md-block">
                    @foreach (var img in Model.ProductImages)
                    {
                        <img src="@img.ImageUrl" class="img-fluid border mb-2 cursor-pointer img-thumbnail-custom" alt="@Model.ProductName" onclick="changeMainImage(this.src)">
                    }
                </div>
                <div class="col-10">
                    <img id="mainProductImage" src="@mainImage" class="img-fluid w-100 object-fit-cover" style="height: 500px; background-color: #f8f9fa;" alt="@Model.ProductName">
                </div>
            </div>
        </div>

        <div class="col-md-5 ps-md-5">
            <h2 class="fw-bold mb-3">@Model.ProductName</h2>

            <div class="d-flex align-items-center mb-4">
                <button type="button" class="btn btn-link text-dark p-0 btn-wishlist me-3" data-product-id="@Model.ProductId" style="font-size: 24px; text-decoration: none;">
                    <i class="fa-regular fa-heart heart-icon-@Model.ProductId"></i>
                </button>
                <h4 class="fw-bold mb-0">@String.Format("{0:0,0}", Model.Price) VND</h4>
            </div>

            <div class="product-details-info" style="font-size: 14px; line-height: 2;">

                @if (!string.IsNullOrEmpty(Model.Dimensions))
                {
                    <p class="mb-1"><strong class="text-dark">Kích thước:</strong> @Model.Dimensions</p>
                }

                @if (!string.IsNullOrEmpty(Model.Material))
                {
                    <p class="mb-1"><strong class="text-dark">Chất liệu:</strong> @Model.Material</p>
                }

                @if (Model.StockQuantity > 0)
                {
                    <p class="mb-3 text-success"><i class="fa-solid fa-check me-1"></i> Hàng có sẵn</p>
                }
                else
                {
                    <p class="mb-3 text-danger"><i class="fa-solid fa-phone me-1"></i> Liên hệ đặt hàng</p>
                }

                <p class="mb-4 text-muted"><strong>Mã:</strong> @Model.ProductId</p>
            </div>
            <div class="d-flex align-items-center mb-4">
                <span class="me-3 fw-bold text-dark">Số lượng:</span>
                <div class="input-group" style="width: 140px;">
                    <button class="btn btn-outline-secondary rounded-0 px-3" type="button" onclick="decreaseQty()">-</button>

                    <input type="text" id="qty-input" name="quantity" class="form-control text-center border-secondary" value="1" readonly>

                    <button class="btn btn-outline-secondary rounded-0 px-3" type="button" onclick="increaseQty()">+</button>
                </div>

                @if (Model.StockQuantity > 0)
                {
                    <span class="ms-3 text-muted" style="font-size: 13px;">(Còn @Model.StockQuantity sản phẩm)</span>
                }
            </div>

            <div class="row g-2 mb-4">
                <div class="col-6">
                    <button type="button" class="btn btn-dark w-100 py-3 rounded-0 fw-bold" onclick="buyNow(@Model.ProductId)">
                        MUA NGAY
                    </button>
                </div>
                <div class="col-6">
                    <button type="button" class="btn btn-outline-dark w-100 py-3 rounded-0 fw-bold" onclick="addToCart(@Model.ProductId)">
                        THÊM VÀO GIỎ
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mt-4 border-top pt-4">
                    <h6 class="fw-bold mb-3 border-bottom d-inline-block pb-2 border-dark">Mô tả</h6>
                    <div class="text-muted" style="font-size: 14px; line-height: 1.8;">
                        @Html.Raw(Model.Description)
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ==========================================
        // 1. ĐỔI ẢNH THUMBNAIL
        // ==========================================
        function changeMainImage(src) {
            document.getElementById('mainProductImage').src = src;
        }

        // ==========================================
        // 2. LOGIC TĂNG GIẢM SỐ LƯỢNG
        // ==========================================
        var maxStock = @(Model.StockQuantity ?? 1);

        function increaseQty() {
            var input = document.getElementById('qty-input');
            var currentVal = parseInt(input.value);
            if (currentVal < maxStock) {
                input.value = currentVal + 1;
            }
        }

        function decreaseQty() {
            var input = document.getElementById('qty-input');
            var currentVal = parseInt(input.value);
            if (currentVal > 1) {
                input.value = currentVal - 1;
            }
        }

        // ==========================================
        // 3. NÚT THÊM VÀO GIỎ HÀNG (Ở lại trang)
        // ==========================================
        function addToCart(productId) {
            var quantity = document.getElementById('qty-input').value;

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: quantity },
                success: function (response) {
                    if (response.success) {
                        // Cộng số lượng trên Menu
                        var currentBadge = $('#cart-badge');
                        var currentCount = parseInt(currentBadge.text().trim()) || 0;
                        currentBadge.text(currentCount + parseInt(quantity));

                        // Báo Toast thành công
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: 'Đã thêm ' + quantity + ' sản phẩm vào giỏ!',
                            showConfirmButton: false,
                            timer: 3000,
                            timerProgressBar: true
                        });
                    } else {
                        if (response.message === "Not logged in") {
                            $('#authModal').modal('show');
                        } else {
                            // Lỗi kho hết hàng
                            Swal.fire({
                                icon: 'error',
                                title: 'Ôi hỏng!',
                                text: response.message,
                                confirmButtonColor: '#212529'
                            });
                        }
                    }
                },
                error: function () {
                    Swal.fire({ icon: 'error', title: 'Lỗi!', text: 'Có lỗi xảy ra, vui lòng thử lại!', confirmButtonColor: '#212529' });
                }
            });
        }

        // ==========================================
        // 4. NÚT MUA NGAY (Thêm vào giỏ + Sang trang Giỏ hàng)
        // ==========================================
        function buyNow(productId) {
            var quantity = document.getElementById('qty-input').value;

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: quantity },
                success: function (response) {
                    if (response.success) {
                        // ĐÃ SỬA: Thêm thành công thì bế khách sang trang Giỏ hàng luôn
                        window.location.href = '/Cart/Index';
                    } else {
                        if (response.message === "Not logged in") {
                            $('#authModal').modal('show');
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Ôi hỏng!',
                                text: response.message,
                                confirmButtonColor: '#212529'
                            });
                        }
                    }
                },
                error: function () {
                    Swal.fire({ icon: 'error', title: 'Lỗi!', text: 'Có lỗi xảy ra, vui lòng thử lại!', confirmButtonColor: '#212529' });
                }
            });
        }
    </script>
}