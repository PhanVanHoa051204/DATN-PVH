@model WebNoiThatHoaHome.Models.OrderItem
@{
    ViewData["Title"] = "Viết đánh giá sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h4 class="fw-bold mb-4 text-uppercase border-start border-dark border-3 ps-3">Viết đánh giá</h4>

            <div class="card rounded-0 border shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        @{
                            var img = Model.Product?.ProductImages?.FirstOrDefault(i => i.IsMain == true)?.ImageUrl ?? "/images/no-image.png";
                        }
                        <img src="@img" class="border" style="width: 80px; height: 80px; object-fit: cover;" />
                        <div class="ms-3">
                            <h6 class="fw-bold mb-1">@Model.Product?.ProductName</h6>
                            <p class="text-muted mb-0" style="font-size: 13px;">Đơn hàng #@Model.OrderId</p>
                            <p class="text-danger fw-bold mb-0" style="font-size: 13px;">@string.Format("{0:N0} ₫", Model.UnitPrice)</p>
                        </div>
                    </div>

                    <form asp-action="PostReview" asp-controller="Product" method="post" id="reviewForm">
                        <input type="hidden" name="productId" value="@Model.ProductId" />

                        <div class="mb-4 text-center">
                            <label class="form-label fw-bold d-block mb-2">Chất lượng sản phẩm</label>
                            <div class="star-rating text-warning" style="cursor: pointer; font-size: 2rem;">
                                <i class="fa-regular fa-star star-btn" data-value="1"></i>
                                <i class="fa-regular fa-star star-btn" data-value="2"></i>
                                <i class="fa-regular fa-star star-btn" data-value="3"></i>
                                <i class="fa-regular fa-star star-btn" data-value="4"></i>
                                <i class="fa-regular fa-star star-btn" data-value="5"></i>
                                <input type="hidden" name="rating" id="ratingValue" value="0" />
                            </div>
                            <small class="text-danger d-none fw-bold mt-1" id="ratingError">Vui lòng chọn số sao!</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Chia sẻ cảm nhận của bạn</label>
                            <textarea name="comment" class="form-control rounded-0 bg-light" rows="4" required placeholder="Sản phẩm dùng tốt không? Màu sắc có giống hình không? Hãy chia sẻ nhé..."></textarea>
                        </div>

                        <div class="text-end border-top pt-3">
                            <a href="/Account/Orders" class="btn btn-light border rounded-0 px-4 me-2">Hủy</a>
                            <button type="submit" class="btn btn-dark rounded-0 px-4">Gửi đánh giá</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Xử lý hiệu ứng khi click vào các ngôi sao
            $('.star-btn').click(function() {
                var val = $(this).data('value');
                $('#ratingValue').val(val);
                $('#ratingError').addClass('d-none'); // Ẩn thông báo lỗi đi

                // Bước 1: Reset tất cả về sao rỗng
                $('.star-btn').removeClass('fa-solid').addClass('fa-regular');

                // Bước 2: Tô màu đặc cho các sao từ 1 đến vị trí vừa click
                $('.star-btn').each(function() {
                    if ($(this).data('value') <= val) {
                        $(this).removeClass('fa-regular').addClass('fa-solid');
                    }
                });
            });

            // Chặn không cho gửi nếu khách lười chưa chịu tick sao nào (rating = 0)
            $('#reviewForm').submit(function(e) {
                if ($('#ratingValue').val() == "0") {
                    e.preventDefault(); // Dừng việc submit form lại
                    $('#ratingError').removeClass('d-none'); // Hiện cảnh báo lên
                }
            });
        });
    </script>
}